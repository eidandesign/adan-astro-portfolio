---
import { getCollection } from "astro:content";
import ConnectSection from "../../components/ConnectSection.astro";
import SEO from "../../components/SEO.astro";
import "../../styles/site.css";

export async function getStaticPaths() {
  const entries = (await getCollection("case-studies")).filter((e) => e.data.kind === "work");
  return entries.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const w = entry.data;
---

<html lang="en">
  <head>
    <SEO title={`${w.title} — Product Design | Adan Careta`} description={w.description} image={w.heroImage} type="article" />
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "CreativeWork",
      name: w.title,
      description: w.description,
      image: new URL(w.heroImage, Astro.site).href,
      url: new URL(Astro.url.pathname, Astro.site).href,
      author: { "@type": "Person", name: "Adan Careta", url: "https://www.adancareta.com" },
      genre: "Product Design",
    })} />
  </head>
  <body class="body-3">
    <a href="/" class="button-return">
      <img src="/images/back_button.svg" loading="lazy" alt="" />
      <div class="paragraph">Home</div>
    </a>

    <div class="page-wrapper">
      <!-- Sticky hero: title + blended hero image; content cards stack over it -->
      <div class="hero-wrapper">
        <section class="hero-section">
          <div class="div-block-52">
            <div class="header-info" id="workHeader">
              <div class="div-block-54">
                <h1 class="title xl center">{w.title}</h1>
                <p class="paragraph center">{w.description}</p>
              </div>
            </div>
            <img src={w.heroImage} alt={w.title} class="image-12" />
          </div>
        </section>
        <div class="spacer"></div>
      </div>

      <!-- Meta + overview card -->
      <div class="contect-wrapper">
        <div class="gray-background">
          <div class="div-block-56">
            <div class="div-block-57">
              {w.role && (
                <div>
                  <div class="labels">my role</div>
                  <div class="paragraph xxl">{w.role}</div>
                </div>
              )}
              {w.team && (
                <div>
                  <div class="labels">Team</div>
                  <div class="paragraph xxl">{w.team}</div>
                </div>
              )}
              {w.improvement && (
                <div>
                  <div class="labels">What we improve</div>
                  <div class="paragraph xxl">{w.improvement}</div>
                </div>
              )}
            </div>
            {w.overview && (
              <div>
                <div class="labels">OVERVIEW</div>
                <div class="paragraph xxl">{w.overview}</div>
              </div>
            )}
          </div>
        </div>
      </div>

      <!-- Design visuals card -->
      <div class="visuals">
        <div class="blue-background">
          <h2 class="title xl">Design</h2>
          {w.gallery.map((img, i) => (
            <img src={img} loading="lazy" alt={`${w.title} design ${i + 1}`} class={i % 2 === 0 ? "image-13" : "image-14"} data-reveal />
          ))}
          {w.figma && (
            <div class="div-block-59" data-reveal>
              <div class="paragraph xxl">{w.figma.text}</div>
              <a href={w.figma.url} target="_blank" rel="noopener" class="button-big">{w.figma.label}</a>
            </div>
          )}
        </div>
      </div>
    </div>

    <ConnectSection />

    <style is:global>
      /* ============ WORK TEMPLATE (from adan-portfolio.webflow.css) ============ */
      .body-3 {
        background-color: var(--surface-background);
      }
      .page-wrapper {
        width: 100%;
      }
      .hero-wrapper {
        z-index: 1;
        margin-bottom: -100vh;
        position: relative;
      }
      .hero-section {
        z-index: 0;
        justify-content: center;
        align-items: flex-start;
        width: 100%;
        min-height: 70vh;
        position: sticky;
        top: 0;
      }
      .div-block-52 {
        display: flex;
        flex-flow: column;
        justify-content: flex-start;
        align-items: flex-start;
        width: 100%;
      }
      .header-info {
        display: flex;
        flex-flow: column;
        justify-content: center;
        align-items: flex-start;
        width: 80%;
        margin-top: 100px;
        margin-left: auto;
        margin-right: auto;
      }
      .div-block-54 {
        display: flex;
        gap: 16px;
        flex-flow: column;
        width: 100%;
      }
      .div-block-54 .title.xl.center {
        width: 100%;
      }
      .div-block-54 .paragraph.center {
        text-align: center;
      }
      .image-12 {
        mix-blend-mode: lighten;
        object-fit: cover;
        background-color: #0c1015;
        border-radius: 30px;
        width: 90%;
        height: 70vh;
        margin-top: 24px;
        margin-left: auto;
        margin-right: auto;
      }
      .spacer {
        height: 110vh;
        position: relative;
      }
      .contect-wrapper {
        z-index: 2;
        min-height: 90vh;
        position: sticky;
        top: 0;
      }
      .gray-background {
        display: flex;
        gap: 24px;
        background-color: #1a1b20;
        border-radius: 30px;
        flex-flow: column;
        justify-content: flex-start;
        align-items: center;
        height: 90vh;
        padding: 200px 56px 80px;
      }
      .div-block-56 {
        display: grid;
        gap: 40px;
        grid-template-rows: auto;
        grid-template-columns: 1fr 1fr;
        width: 80%;
        margin-left: auto;
        margin-right: auto;
      }
      .div-block-57 {
        display: flex;
        gap: 40px;
        flex-flow: column;
      }
      .visuals {
        z-index: 2;
        min-height: 100vh;
        position: sticky;
        top: 0;
      }
      .blue-background {
        display: flex;
        gap: 80px;
        background-color: #0e0f12;
        border-radius: 30px;
        flex-flow: column;
        justify-content: center;
        align-items: center;
        padding: 140px 0;
      }
      .image-13 {
        max-width: 50%;
      }
      .image-14 {
        max-width: 50%;
      }
      .div-block-59 {
        display: flex;
        gap: 30px;
        flex-flow: column;
        align-items: center;
      }

      @media (max-width: 991px) {
        .gray-background {
          justify-content: center;
          align-items: center;
          height: auto;
          padding: 56px 23px 56px 12px;
        }
        .div-block-56 {
          grid-template-columns: 1fr;
        }
        .blue-background {
          gap: 40px;
          min-height: 100vh;
          padding-top: 80px;
          padding-bottom: 80px;
        }
      }

      @media (max-width: 767px) {
        .image-12 {
          height: 50vh;
        }
        .image-13,
        .image-14 {
          max-width: 80%;
        }
      }
    </style>

    <script>
      import gsap from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";

      gsap.registerPlugin(ScrollTrigger);

      /* Title + hero image entrance */
      gsap.from("#workHeader", { y: 60, opacity: 0, duration: 1.1, ease: "power3.out", delay: 0.1 });
      gsap.from(".image-12", { y: 80, opacity: 0, duration: 1.2, ease: "power3.out", delay: 0.35 });

      /* Generic reveals */
      document.querySelectorAll<HTMLElement>("[data-reveal]").forEach((el) => {
        gsap.to(el, {
          opacity: 1,
          y: 0,
          duration: 1,
          ease: "power3.out",
          scrollTrigger: { trigger: el, start: "top 88%", once: true },
        });
      });
    </script>
  </body>
</html>
