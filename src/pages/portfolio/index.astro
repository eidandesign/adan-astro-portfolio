---
import { Layout } from '@/layouts/Layout';
import { ProjectCard } from '@/components/ProjectCard';
import { client, PROJECTS_QUERY } from '@/utils/sanity';

const projects = await client.fetch(PROJECTS_QUERY);
---

<Layout title="Portfolio - Adan Careta" description="Explore my product design portfolio and case studies">
  <section class="pt-32 pb-20 bg-white">
    <div class="max-w-7xl mx-auto px-6">
      {/* Header */}
      <div class="mb-16">
        <h1 class="text-5xl font-bold text-gray-900 mb-6">My Portfolio</h1>
        <p class="text-xl text-gray-600 max-w-2xl">
          A selection of projects spanning product design, UI/UX, design systems, branding, and AI experiences.
        </p>
      </div>

      {/* Filter by Category */}
      <div class="mb-12 flex gap-4 flex-wrap">
        <a href="/portfolio" class="px-4 py-2 bg-gray-900 text-white rounded-full text-sm font-medium">
          All
        </a>
        <a href="/portfolio?category=product-design" class="px-4 py-2 bg-gray-100 text-gray-700 rounded-full text-sm font-medium hover:bg-gray-200 transition">
          Product Design
        </a>
        <a href="/portfolio?category=branding" class="px-4 py-2 bg-gray-100 text-gray-700 rounded-full text-sm font-medium hover:bg-gray-200 transition">
          Branding
        </a>
        <a href="/portfolio?category=ui-ux" class="px-4 py-2 bg-gray-100 text-gray-700 rounded-full text-sm font-medium hover:bg-gray-200 transition">
          UI/UX
        </a>
        <a href="/portfolio?category=design-systems" class="px-4 py-2 bg-gray-100 text-gray-700 rounded-full text-sm font-medium hover:bg-gray-200 transition">
          Design Systems
        </a>
      </div>

      {/* Projects Grid */}
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        {projects.map((project: any, index: number) => (
          <ProjectCard key={project._id} project={project} index={index} client:load />
        ))}
      </div>

      {/* Empty state */}
      {projects.length === 0 && (
        <div class="text-center py-20">
          <p class="text-gray-600">No projects found. Check back soon!</p>
        </div>
      )}
    </div>
  </section>
</Layout>
