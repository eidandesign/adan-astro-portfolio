---
// Homepage — faithful rebuild of www.adancareta.com (Webflow) in Astro,
// with GSAP ScrollTrigger animations.

import { getCollection } from "astro:content";
import ConnectSection from "../components/ConnectSection.astro";
import SEO from "../components/SEO.astro";
import "../styles/site.css";

// Case studies + work cards come from the Markdown CMS (src/content/case-studies/)
const entries = await getCollection("case-studies");
const caseStudies = entries
  .filter((e) => e.data.kind === "case-study")
  .sort((a, b) => a.data.order - b.data.order);
const workCards = entries
  .filter((e) => e.data.kind === "work")
  .sort((a, b) => a.data.order - b.data.order);

const aboutItems = [
  {
    number: "{.01}",
    title: "Product",
    description:
      "I design user-centric, functional products using research, AI tools, and prototyping to solve problems and deliver impactful, intuitive solutions that drive business results.",
  },
  {
    number: "{.02}",
    title: "Visual",
    description:
      "I create visually stunning, cohesive designs with strategic use of typography, color, and layout to elevate clarity, storytelling, and user engagement.",
  },
  {
    number: "{.03}",
    title: "UX/UI",
    description:
      "I craft intuitive, accessible, and responsive interfaces, combining usability, seamless interactions, and high-fidelity prototypes to enhance user experiences.",
  },
  {
    number: "{.04}",
    title: "Art Direction",
    description:
      "I lead creative visions and align teams to deliver strategic, consistent designs that resonate with audiences, maintain high standards, and drive meaningful outcomes.",
  },
];

const companies = [
  { img: "/images/citibank-5-1.svg", alt: "Citibank" },
  { text: "Digital Experiences" },
  { img: "/images/nasa_logo.svg.svg", alt: "NASA" },
  { text: "E-Commerce" },
  { img: "/images/mattel_logo.svg.svg", alt: "Mattel" },
  { text: "App Games" },
  { text: "Custom Software" },
  { img: "/images/codelitt_logo.svg.png", alt: "Codelitt" },
  { text: "Investment Solutions" },
  { img: "/images/american_century_investments_logo.svg.svg", alt: "American Century Investments" },
  { text: "Interactive Apps" },
  { img: "/images/the_coca-cola_company_logo.svg.svg", alt: "The Coca-Cola Company" },
  { img: "/images/el_palacio_de_hierro_logo.svg.avif", alt: "El Palacio de Hierro" },
  { text: "Fashion Design" },
  { img: "/images/pfizer_1pfizer.avif", alt: "Pfizer" },
  { text: "Health Digital Experiences" },
  { img: "/images/jll_logo.svg_1jll_logo.svg.avif", alt: "JLL" },
  { text: "Digital Experiences" },
];
---

<html lang="en">
  <head>
    <SEO
      title="Adan Careta — Product Designer | Human-Centric Design Solutions"
      description="Adan Careta is a multidisciplinary product designer creating user-centric digital experiences through research, AI-powered design, and prototyping. Case studies for Stanza, NASA-adjacent SpaceMart, Coca-Cola and more."
    />
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      name: "Adan Careta",
      jobTitle: "Product Designer",
      url: "https://www.adancareta.com",
      image: "https://www.adancareta.com/images/og-adan-careta.jpg",
      email: "mailto:design.adan@gmail.com",
      address: { "@type": "PostalAddress", addressCountry: "MX" },
      sameAs: [
        "https://www.linkedin.com/in/acareta/",
        "https://www.behance.net/eidan",
        "https://www.instagram.com/adancaretadg",
      ],
      knowsAbout: ["Product Design", "UX/UI Design", "Visual Design", "Art Direction", "Design Systems"],
    })} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@1,500;1,600;1,700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="body">
    <h1 class="sr-only">Adan Careta — Innovative Product Designer with Human-Centric Solutions</h1>
    <!-- NAVBAR -->
    <div class="navbar" role="banner">
      <a href="/" aria-current="page" class="brand">
        <div class="brand-text">
          <h4 class="title small">Adan Careta H.</h4>
          <div class="paragraph small">Shaping new ideas, fixing existing.</div>
        </div>
      </a>

      <button class="menu-button" id="menuButton" aria-label="Open menu" aria-expanded="false" aria-controls="navMenu" type="button">
        <div class="menu-wrapper">
          <!-- Heroicons: Menu (24x24) -->
          <svg class="menu-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
          </svg>
          <!-- Heroicons: X Mark (24x24) -->
          <svg class="close-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
          </svg>
        </div>
      </button>

      <nav role="navigation" class="nav-menu" id="navMenu">
        <div class="nav-items">
          <a href="#CaseStudies" class="navbar-item" data-nav-anim>
            <div class="navbar-item-top">Case Studies</div>
            <div class="navbar-item-bottom">Work Process</div>
          </a>
          <a href="#letsconnect" class="navbar-item" data-nav-anim>
            <div class="navbar-item-top">Let&#x27;s Connect</div>
            <div class="navbar-item-bottom">Contact Me</div>
          </a>
        </div>
        <!-- Small screens hide the CV button and the social rail in the
             corner, so the menu is the only place they can live. -->
        <div class="nav-extras">
          <a
            href="https://www.dropbox.com/scl/fi/1w5li3o7ozm1qyjrjgwnq/adancareta-2026.pdf?rlkey=c1qs1j6kbqkxjku0v2s7j7aa6&dl=1"
            target="_blank"
            rel="noopener"
            class="cv-button glass"
            data-nav-anim>
            <span>Download CV</span>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" />
            </svg>
          </a>
          <div class="nav-social" data-nav-anim>
            <a href="https://www.linkedin.com/in/acareta/" target="_blank" rel="noopener" class="social-media---link" aria-label="LinkedIn">
              <div class="icon-container"><img src="/images/adan-linkedin.svg" loading="lazy" alt="" class="image" /></div>
            </a>
            <a href="mailto:design.adan@gmail.com?subject=Hey%20Adan!%20" class="social-media---link" aria-label="Email">
              <div class="icon-container"><img src="/images/adan-email.svg" loading="lazy" alt="" class="image" /></div>
            </a>
            <a href="https://www.behance.net/eidan" target="_blank" rel="noopener" class="social-media---link" aria-label="Behance">
              <div class="icon-container"><img src="/images/adan-behance.svg" loading="lazy" alt="" class="image" /></div>
            </a>
            <a href="https://www.instagram.com/adancaretadg" target="_blank" rel="noopener" class="social-media---link" aria-label="Instagram">
              <div class="icon-container"><img src="/images/adan-instagram.svg" loading="lazy" alt="" class="image" /></div>
            </a>
          </div>
        </div>
      </nav>
    </div>

    <!-- RIGHT TOOL RAIL -->
    <div class="right-tool">
      <div class="right-panel">
        <div class="mexico">
          <div class="labels white">México City<br />Pacific Center</div>
          <div class="lottie-animation" id="sunLottie"></div>
        </div>
        <div class="timer">
          <div id="mexico-time" class="titles-medium">10:24</div>
        </div>
      </div>
      <div class="social-links">
        <a href="https://www.linkedin.com/in/acareta/" target="_blank" rel="noopener" class="social-media---link" aria-label="LinkedIn">
          <div class="icon-container"><img src="/images/adan-linkedin.svg" loading="lazy" alt="" class="image" /></div>
        </a>
        <a href="mailto:design.adan@gmail.com?subject=Hey%20Adan!%20" class="social-media---link" aria-label="Email">
          <div class="icon-container"><img src="/images/adan-email.svg" loading="lazy" alt="" class="image" /></div>
        </a>
        <a href="https://www.behance.net/eidan" target="_blank" rel="noopener" class="social-media---link" aria-label="Behance">
          <div class="icon-container"><img src="/images/adan-behance.svg" loading="lazy" alt="" class="image" /></div>
        </a>
        <a href="https://www.instagram.com/adancaretadg" target="_blank" rel="noopener" class="social-media---link" aria-label="Instagram">
          <div class="icon-container"><img src="/images/adan-instagram.svg" loading="lazy" alt="" class="image" /></div>
        </a>
      </div>
      <!-- dl=1 makes Dropbox serve the file directly instead of opening its
           preview page. -->
      <a
        href="https://www.dropbox.com/scl/fi/1w5li3o7ozm1qyjrjgwnq/adancareta-2026.pdf?rlkey=c1qs1j6kbqkxjku0v2s7j7aa6&dl=1"
        target="_blank"
        rel="noopener"
        class="cv-button glass">
        <span>Download CV</span>
        <!-- Heroicons: arrow-down-tray -->
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" />
        </svg>
      </a>
    </div>

    <!-- HERO (desktop) -->
    <section class="section-hero">
      <div class="flex-block" id="heroBlock">
        <div class="gradiend-background" id="heroGradient"></div>
        <div class="line-1">
          <span class="title xxl hero-line">Innovative</span>
          <img loading="eager" src="/images/adancareta_1.avif" alt="Adan Careta" class="hero-picture" />
        </div>
        <div class="flex-below-picture hero-line">
          <span id="typewriter-text" class="text-changing">Product</span>
          <span class="title xxl">Designer</span>
        </div>
        <span class="title xxl hero-line">with Human-Centric</span>
        <div class="div-block-8 hero-line">
          <span class="title xxl">Solutions</span>
          <div class="div-block-2">
            <div class="paragraph big">Helping products thrive with AI-powered design for smarter, functional ideas</div>
          </div>
        </div>
      </div>
    </section>

    <!-- HERO (mobile) -->
    <section class="section-hero-mobile">
      <!-- Outside .flex-block-mobile on purpose: GSAP leaves a transform on
           that block, and a transformed element becomes the containing block
           for absolutely positioned descendants — which dragged the glow
           along with the headline. As a child of the section it stays put. -->
      <div class="gradiend-background"></div>
      <div class="flex-block-mobile" id="heroBlockMobile">
        <div class="line-1">
          <span class="title xxl mobile">Innovative</span>
          <img loading="eager" src="/images/adancareta_1.avif" alt="Adan Careta" class="hero-picture-mobile" />
        </div>
        <div class="div-block-44">
          <span id="typewriter-text-2" class="text-changing">Product</span>
          <span class="title xxl mobile">Designer</span>
        </div>
        <span class="title xxl mobile">with Human-Centric</span>
        <div class="div-block-8">
          <span class="title xxl mobile">Solutions</span>
          <div class="div-block-2">
            <div class="paragraph big">Helping products grow with AI-enhanced design for smarter, impactful solutions.</div>
          </div>
        </div>
      </div>
    </section>

    <!-- STICKY QUOTE GRID (scroll-driven) -->
    <div class="quote-section" id="quoteSection">
      <div class="grid-mask">
        <div class="quick-stack" id="quickStack">
          <div class="qs-cell cell-4 span-2" data-qs="left">
            <img src="/images/nasa-cateni_1nasa-cateni.avif" loading="lazy" alt="NASA Cateni project" class="other-image" />
          </div>
          <div class="qs-cell cell-6 span-2" data-qs="quote">
            <div class="div-block-43">
              <div class="title big">&quot;You can’t design something for everyone if you don’t understand anyone.&quot;</div>
              <div class="labels">– Jared Spool</div>
            </div>
          </div>
          <div class="qs-cell cell-5"><div class="div-color"></div></div>
          <div class="qs-cell span-2 video-cell" data-qs="video">
            <div class="main-image-mask" id="videoMask">
              <video
                autoplay
                loop
                muted
                playsinline
                poster="/video/adan-video-poster.jpg"
                class="background-video"
              >
                <source src="/video/adan-video.mp4" type="video/mp4" />
                <source src="/video/adan-video.webm" type="video/webm" />
              </video>
            </div>
          </div>
          <div class="qs-cell cell-3"><div class="div-color"></div></div>
          <div class="qs-cell" data-qs="bottom">
            <img src="/images/tolktu_1tolktu.avif" loading="lazy" alt="Tolktu project" class="other-image" />
          </div>
          <div class="qs-cell span-2"></div>
          <div class="qs-cell" data-qs="right">
            <img src="/images/stanza-warriors_1stanza-warriors.avif" loading="lazy" alt="Stanza Warriors project" class="other-image" />
          </div>
        </div>
      </div>
    </div>

    <!-- ABOUT -->
    <section class="section-about-me">
      <div class="div-block-25">
        <div class="text-block-2">About</div>
      </div>
      <div class="grid">
        {aboutItems.map((item, i) => (
          <div class="about-me" data-stack-card style={`--i:${i}`}>
            <div class="labels">{item.number}<br />‍</div>
            <h3 class="titles medium">{item.title}</h3>
            <p class="paragraph big about">{item.description}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- CASE STUDIES -->
    <section id="CaseStudies" class="section-studies">
      <h2 class="title xl center" data-reveal>Case Studies</h2>
      <div class="project-div">
        {caseStudies.map(({ slug, data: cs }) => (
          <div class="collection-item">
            <div class="case-study-preview">
              <div class="cs-cell">
                <div class="info-container" data-reveal>
                  <div class="div-block-18">
                    <h3 class="title medium">{cs.title}</h3>
                    <div class="labels _100">{cs.cardLabels}</div>
                  </div>
                  <p class="paragraph big">{cs.description}</p>
                  <a href={`/case-studies/${slug}`} class="buttons">Read Case Study</a>
                </div>
              </div>
              <div class="cs-cell cell-2">
                <div class="image-case-study-container">
                  <img src={cs.cardImage ?? cs.heroImage} loading="lazy" alt={cs.title} class="main-images left-aligment" data-parallax />
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- CLIENTS -->
    <section class="section-clients">
      <div class="div-block-24">
        <div class="div-block-22">
          <div class="text-horizontal-effect" data-marquee="right">Brands That Trusted My Vision</div>
          <p class="paragraph medium centered">
            I’ve had the privilege of collaborating with incredible teams on projects that push boundaries, solve real
            problems, and deliver meaningful results.
          </p>
          <div class="text-horizontal-effect" data-marquee="left">to Solve User Challenges</div>
        </div>
      </div>
      <div>
        <div class="div-block-21">
          {companies.map((c) => (
            <div class="company-item" data-company>
              {c.img ? <img loading="lazy" src={c.img} alt={c.alt} /> : <div class="company-text">{c.text}</div>}
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- WORK -->
    <section class="section-work">
      <h2 class="titles big" data-reveal>Work</h2>
      <div class="collection-list">
        {workCards.map(({ slug, data: card }, i) => (
          <a href={`/portfolio/${slug}`} class="work-card" data-reveal>
            <div class="labels">{String(i + 1).padStart(3, "0")}</div>
            <div class="div-block-58">
              <img src={card.cardImage ?? card.heroImage} loading="lazy" alt={card.title} class="image-10" />
            </div>
            <div class="div-block-51">
              <div class="title big">{card.title}</div>
              <div class="paragraph">{card.description}</div>
            </div>
            <div class="tags">
              {card.tags.map((tag) => (
                <div class="tag">{tag}</div>
              ))}
            </div>
          </a>
        ))}
      </div>
    </section>

    <ConnectSection />

    <!-- CLOSING QUOTE -->
    <section class="section-things-that-i-know">
      <div class="div-block-26">
        <div class="last-quote" data-reveal>
          Design doesn’t belong to those who create it. It belongs to those <br />who use it.
        </div>
      </div>
    </section>


    <script>
      import gsap from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";
      import lottie from "lottie-web";

      gsap.registerPlugin(ScrollTrigger);

      const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      // Each feature below runs independently — if one throws (e.g. a lazy
      // asset fails, a selector comes back empty), it must not stop the rest
      // of the page's animations from wiring up. On any failure we fall back
      // to the always-visible CSS state (see html.gsap-failed in site.css)
      // instead of leaving content permanently at its hidden "from" state.
      function safeRun(label: string, fn: () => void) {
        try {
          fn();
        } catch (err) {
          console.error(`[gsap:${label}]`, err);
          document.documentElement.classList.add("gsap-failed");
          document.querySelectorAll<HTMLElement>(".flex-block, .flex-block-mobile").forEach((b) => {
            gsap.set(b, { opacity: 1 });
          });
        }
      }

      /* ---------- Typewriter (ported from live site) ---------- */
      function typewriter(el: HTMLElement | null, words: string[]) {
        if (!el || reduceMotion) return;
        const typingPerLetter = 0.15;
        const deletingPerLetter = 0.1;
        const pauseBetween = 1.5;
        let index = 0;

        function cycle() {
          if (!el) return;
          const word = words[index];
          const typingDuration = typingPerLetter * word.length;
          const deletingDuration = deletingPerLetter * word.length;
          const steps = word.length * 4;

          el.style.setProperty("--typing-duration", `${typingDuration}s`);
          el.style.setProperty("--typing-steps", String(steps));
          el.style.setProperty("--deleting-duration", `${deletingDuration}s`);
          el.style.setProperty("--deleting-steps", String(steps));

          el.classList.remove("deleting");
          void el.offsetWidth;
          el.textContent = word;
          el.classList.add("typing");

          setTimeout(() => {
            setTimeout(() => {
              el.classList.remove("typing");
              el.classList.add("deleting");
              setTimeout(() => {
                index = (index + 1) % words.length;
                cycle();
              }, deletingDuration * 1000);
            }, pauseBetween * 1000);
          }, typingDuration * 1000);
        }
        cycle();
      }

      safeRun("typewriter", () => {
        typewriter(document.getElementById("typewriter-text"), ["Product", "Visual", "UX|UI", "Director", "Creative"]);
        typewriter(document.getElementById("typewriter-text-2"), ["Product", "UX/UI", "Brand", "Visual", "Director"]);
      });

      /* ---------- Mexico City time ---------- */
      function updateMexicoCityTime() {
        const el = document.querySelector("#mexico-time");
        if (!el) return;
        /* 12-hour clock without the AM/PM suffix, per the header design. */
        el.textContent = new Date()
          .toLocaleTimeString("en-US", {
            timeZone: "America/Mexico_City",
            hour: "2-digit",
            minute: "2-digit",
            hour12: true,
          })
          .replace(/\s*(AM|PM)$/i, "");
      }
      safeRun("mexico-time", () => {
        updateMexicoCityTime();
        setInterval(updateMexicoCityTime, 60000);
      });

      /* ---------- Lottie sun ---------- */
      safeRun("lottie", () => {
        const sunContainer = document.getElementById("sunLottie");
        if (sunContainer) {
          lottie.loadAnimation({
            container: sunContainer,
            renderer: "svg",
            loop: true,
            autoplay: true,
            path: "/lottie/sun.json",
          });
        }
      });

      /* ---------- Mobile menu ---------- */
      safeRun("mobile-menu", () => {
        const menuButton = document.getElementById("menuButton");
        const navMenu = document.getElementById("navMenu");
        if (menuButton && navMenu) {
          const rows = gsap.utils.toArray<HTMLElement>("[data-nav-anim]", navMenu);
          let tl: gsap.core.Timeline | null = null;

          const setOpen = (open: boolean) => {
            menuButton.classList.toggle("open", open);
            menuButton.setAttribute("aria-expanded", String(open));
            menuButton.setAttribute("aria-label", open ? "Close menu" : "Open menu");
            document.documentElement.style.overflow = open ? "hidden" : "";

            if (reduceMotion) {
              navMenu.classList.toggle("open", open);
              return;
            }

            tl?.kill();

            /* The reveal is a circle centred on the menu button, so the
               panel looks like it grows out from under the thumb — and
               clipping the element clips its backdrop-filter with it, so
               the frost wipes in along the same edge. */
            const b = menuButton.getBoundingClientRect();
            const ox = ((b.left + b.width / 2) / window.innerWidth) * 100;
            const oy = ((b.top + b.height / 2) / window.innerHeight) * 100;
            const from = `circle(0% at ${ox}% ${oy}%)`;
            const to = `circle(140% at ${ox}% ${oy}%)`;

            if (open) {
              navMenu.classList.add("open");
              tl = gsap
                .timeline()
                .fromTo(
                  navMenu,
                  { clipPath: from, "--menu-blur": "0px" },
                  { clipPath: to, "--menu-blur": "30px", duration: 0.75, ease: "power3.inOut" }
                )
                .fromTo(
                  rows,
                  { y: 48, scale: 0.94, opacity: 0 },
                  { y: 0, scale: 1, opacity: 1, duration: 0.65, stagger: 0.07, ease: "power3.out" },
                  0.2
                );
            } else {
              tl = gsap
                .timeline({
                  onComplete: () => {
                    navMenu.classList.remove("open");
                    gsap.set([navMenu, ...rows], { clearProps: "all" });
                  },
                })
                /* Rows leave bottom-first, the reverse of how they arrived */
                .to(rows, {
                  y: 28,
                  scale: 0.96,
                  opacity: 0,
                  duration: 0.32,
                  stagger: { each: 0.05, from: "end" },
                  ease: "power2.in",
                })
                .to(
                  navMenu,
                  { clipPath: from, "--menu-blur": "0px", duration: 0.5, ease: "power3.inOut" },
                  0.15
                );
            }
          };
          menuButton.addEventListener("click", () => setOpen(!navMenu.classList.contains("open")));
          document.addEventListener("keydown", (e) => {
            if (e.key === "Escape" && navMenu.classList.contains("open")) {
              setOpen(false);
              menuButton.focus();
            }
          });
          navMenu.querySelectorAll("a").forEach((a) => a.addEventListener("click", () => setOpen(false)));
        }
      });

      /* ---------- GSAP: hero load-in ---------- */
      safeRun("hero-load-in", () => {
        const visibleHero =
          window.getComputedStyle(document.querySelector(".section-hero")!).display === "none"
            ? document.getElementById("heroBlockMobile")
            : document.getElementById("heroBlock");
        if (visibleHero) {
          gsap.set(visibleHero, { opacity: 1 });
          if (!reduceMotion) {
            const lines = visibleHero.querySelectorAll("span.title, span.text-changing, .div-block-2, .div-block-44");
            gsap.from(lines, {
              y: 80,
              opacity: 0,
              duration: 1.1,
              stagger: 0.12,
              ease: "power3.out",
              delay: 0.15,
            });
          }
        }
        // Fallback: make sure both hero blocks are visible even if detection failed
        document.querySelectorAll<HTMLElement>(".flex-block, .flex-block-mobile").forEach((b) => {
          if (Number(window.getComputedStyle(b).opacity) === 0) gsap.set(b, { opacity: 1 });
        });
      });

      /* ---------- GSAP: gradient blob drift + hero parallax ---------- */
      safeRun("gradient-parallax", () => {
        if (reduceMotion) return;
        /* Drift stays on the desktop blob only: the mobile/tablet ones carry
           their placement in a CSS `transform`, which GSAP's x/y would
           overwrite. Their glow still pulses — opacity is transform-safe. */
        const gradient = document.getElementById("heroGradient");
        if (gradient) {
          gsap.to(gradient, {
            x: 40,
            y: -28,
            scale: 1.08,
            duration: 9,
            yoyo: true,
            repeat: -1,
            ease: "sine.inOut",
          });
        }
        /* 9s drift against a 5.5s glow: the periods never line up, so the
           loop never repeats the same combination — that mismatch is what
           reads as alive instead of as a looping animation. */
        gsap.to(".gradiend-background", {
          opacity: 0.7,
          duration: 5.5,
          yoyo: true,
          repeat: -1,
          ease: "sine.inOut",
        });
        document.querySelectorAll<HTMLElement>(".section-hero, .section-hero-mobile").forEach((hero) => {
          const block = hero.querySelector(".flex-block, .flex-block-mobile");
          if (!block) return;
          gsap.to(block, {
            yPercent: -12,
            opacity: 0.25,
            ease: "none",
            scrollTrigger: { trigger: hero, start: "bottom bottom", end: "bottom 20%", scrub: true },
          });
        });
      });

      /* ---------- GSAP: sticky quote-grid choreography ---------- */
      safeRun("quote-grid", () => {
        if (reduceMotion) return;
        const quoteSection = document.getElementById("quoteSection");
        if (quoteSection) {
          const tl = gsap.timeline({
            scrollTrigger: {
              trigger: quoteSection,
              start: "top top",
              end: "bottom bottom",
              scrub: 1,
            },
          });

          // Video starts as the full-screen protagonist, then settles into its grid cell
          tl.fromTo(
            "#videoMask",
            { scale: 2.4, borderRadius: 0 },
            { scale: 1, borderRadius: 8, duration: 4, ease: "power2.inOut" },
            0
          );
          // Side images slide in from the edges while the video shrinks
          tl.from('[data-qs="left"]', { xPercent: -130, rotation: -4, duration: 3, ease: "power2.out" }, 1.2);
          tl.from('[data-qs="bottom"]', { yPercent: 140, duration: 3, ease: "power2.out" }, 1.8);
          tl.from('[data-qs="right"]', { xPercent: 140, rotation: 4, duration: 3, ease: "power2.out" }, 2.2);
          // The quote lands last
          tl.from(
            '[data-qs="quote"] > *',
            { y: 70, opacity: 0, duration: 2.4, stagger: 0.5, ease: "power3.out" },
            3.4
          );
          // Gentle parallax drift for the tail of the scroll
          tl.to('[data-qs="left"] img, [data-qs="bottom"] img, [data-qs="right"] img', {
            yPercent: -8,
            duration: 3,
            ease: "none",
          });
        }
      });

      /* ---------- GSAP: About — stacked cards recede ---------- */
      safeRun("about-stack", () => {
        if (reduceMotion) return;
        const grid = document.querySelector<HTMLElement>(".section-about-me .grid");
        const cards = gsap.utils.toArray<HTMLElement>("[data-stack-card]");
        if (!grid || cards.length < 2) return;

        cards.forEach((card, i) => {
          const next = cards[i + 1];
          if (!next) return;
          /* Sticky elements report a shifted bounding rect once pinned, so
             the scroll range is derived from offsetTop — pure layout, which
             sticky never changes — rather than from a live rect. */
          const nextDocTop = () =>
            grid.getBoundingClientRect().top + window.scrollY + next.offsetTop;
          const stickyTop = (el: HTMLElement) => parseFloat(getComputedStyle(el).top) || 0;

          gsap.to(card, {
            scale: 0.94,
            "--dim": 0.62,
            ease: "none",
            scrollTrigger: {
              /* Numeric start/end are absolute scroll positions, scoped to
                 the exact window where the next card overlaps this one:
                 from its top touching this card's bottom edge, until it
                 settles into its own pinned slot. Keying off the viewport
                 instead would start the fade while the card is still alone
                 on screen. */
              start: () => nextDocTop() - stickyTop(card) - card.offsetHeight,
              end: () => nextDocTop() - stickyTop(next),
              scrub: true,
              invalidateOnRefresh: true,
            },
          });
        });
      });

      /* ---------- GSAP: generic reveals ---------- */
      safeRun("reveals", () => {
        document.querySelectorAll<HTMLElement>("[data-reveal]").forEach((el) => {
          gsap.to(el, {
            opacity: 1,
            y: 0,
            duration: 1,
            ease: "power3.out",
            scrollTrigger: { trigger: el, start: "top 85%", once: true },
          });
        });
      });

      /* ---------- GSAP: case-study image parallax ---------- */
      safeRun("case-study-parallax", () => {
        if (reduceMotion) return;
        document.querySelectorAll<HTMLElement>("[data-parallax]").forEach((img) => {
          gsap.fromTo(
            img,
            { yPercent: -18 },
            {
              yPercent: 0,
              ease: "none",
              scrollTrigger: { trigger: img.parentElement, start: "top bottom", end: "bottom top", scrub: true },
            }
          );
        });
      });

      /* ---------- GSAP: horizontal text effect ---------- */
      safeRun("marquee", () => {
        if (reduceMotion) return;
        document.querySelectorAll<HTMLElement>("[data-marquee]").forEach((el) => {
          const dir = el.dataset.marquee === "left" ? 1 : -1;
          /* Travel half the hidden width in each direction, so the whole
             sentence sweeps through the clip window over the scroll. A flat
             percentage left the long lines permanently cut off on narrow
             screens, where the text overflows by more than it ever moved.
             The floor keeps the original drift where the line already fits. */
          const travel = () =>
            Math.max((el.scrollWidth - el.clientWidth) / 2 + 16, el.clientWidth * 0.12);
          gsap.fromTo(
            el,
            { x: () => travel() * dir },
            {
              x: () => -travel() * dir,
              ease: "none",
              scrollTrigger: {
                trigger: el,
                start: "top bottom",
                end: "bottom top",
                scrub: true,
                invalidateOnRefresh: true,
              },
            }
          );
        });
      });

      /* ---------- GSAP: company grid stagger ---------- */
      safeRun("company-grid", () => {
        const companyItems = document.querySelectorAll("[data-company]");
        if (companyItems.length && !reduceMotion) {
          gsap.from(companyItems, {
            opacity: 0,
            y: 30,
            duration: 0.7,
            stagger: { each: 0.05, from: "random" },
            ease: "power2.out",
            scrollTrigger: { trigger: ".div-block-21", start: "top 85%", once: true },
          });
        }
      });

    </script>
  </body>
</html>
