---
const projects = [
  {
    title: "NASA Cateni",
    category: "UX/UI · Dashboard",
    description: "Designed a complex data visualization dashboard for NASA's internal tools, focused on clarity and fast decision-making.",
    image: "/images/nasa-cateni_1.avif",
    slug: "nasa-cateni",
    tags: ["Dashboard", "Enterprise UX", "Data Viz"]
  },
  {
    title: "Taskeeter",
    category: "Product Design · Mobile",
    description: "End-to-end product design for a task management app with AI-assisted prioritization and team collaboration features.",
    image: "/images/taskeeter-header.jpg",
    slug: "taskeeter",
    tags: ["Mobile", "AI", "Productivity"]
  },
  {
    title: "Tolktu",
    category: "UX Strategy · Marketplace",
    description: "Redesigned the core shopping experience for a multi-retailer marketplace, reducing checkout friction and improving conversion.",
    image: "/images/tolktu_1.avif",
    slug: "tolktu",
    tags: ["Marketplace", "E-commerce", "UX Strategy"]
  },
  {
    title: "Stanza Warriors",
    category: "Brand · Web Design",
    description: "Brand identity and web design for a creative gaming studio, blending editorial aesthetics with immersive visual language.",
    image: "/images/stanza-warriors_1.avif",
    slug: "stanza-warriors",
    tags: ["Branding", "Web", "Gaming"]
  }
];
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Adan Careta — Senior Product Designer</title>
  <style>
    @font-face {
      font-family: 'Switzer';
      src: url('/fonts/Switzer-Regular.otf') format('opentype');
      font-weight: 400;
    }
    @font-face {
      font-family: 'Switzer';
      src: url('/fonts/Switzer-Medium.otf') format('opentype');
      font-weight: 500;
    }
    @font-face {
      font-family: 'Switzer';
      src: url('/fonts/Switzer-Semibold.otf') format('opentype');
      font-weight: 600;
    }
    @font-face {
      font-family: 'Switzer';
      src: url('/fonts/Switzer-Bold.otf') format('opentype');
      font-weight: 700;
    }
    @font-face {
      font-family: 'Powergrotesk';
      src: url('/fonts/PowerGrotesk-Medium.otf') format('opentype');
      font-weight: 500;
    }
    @font-face {
      font-family: 'Powergrotesk';
      src: url('/fonts/PowerGrotesk-Light.otf') format('opentype');
      font-weight: 300;
    }

    :root {
      --bg: #0c1015;
      --text-primary: #dfe6f5;
      --text-secondary: #b7a498;
      --accent: #f95640;
      --border: #181716;
      --surface: #13181f;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      background-color: var(--bg);
      color: var(--text-primary);
      font-family: 'Powergrotesk', Arial, sans-serif;
      font-weight: 300;
      overflow-x: hidden;
    }

    a { text-decoration: none; color: inherit; }

    ::selection { color: var(--accent); background: #fff; }

    /* NAV */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      padding: 20px 40px;
      background: transparent;
    }

    .nav-brand {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .nav-brand-text h4 {
      font-family: 'Powergrotesk', Arial, sans-serif;
      font-size: 15px;
      font-weight: 500;
      color: var(--text-primary);
      letter-spacing: 0.2px;
    }

    .nav-brand-text p {
      font-family: 'Switzer', Arial, sans-serif;
      font-size: 11px;
      color: var(--text-secondary);
      font-weight: 400;
    }

    .nav-links {
      display: flex;
      gap: 0;
      justify-self: center;
    }

    .nav-item {
      display: flex;
      flex-direction: column;
      padding: 8px 24px;
      border-left: 1px solid var(--border);
      cursor: pointer;
      transition: opacity 0.2s;
    }

    .nav-item:hover {
      opacity: 0.8;
    }

    .nav-item:last-child {
      border-right: 1px solid var(--border);
    }

    .nav-item-top {
      font-family: 'Powergrotesk', Arial, sans-serif;
      font-size: 15px;
      font-weight: 300;
      color: #fff;
    }

    .nav-item-bottom {
      font-family: 'Switzer', Arial, sans-serif;
      font-size: 11px;
      font-weight: 300;
      color: var(--text-secondary);
    }

    /* HAMBURGER MENU */
    .hamburger {
      display: none;
      flex-direction: column;
      gap: 6px;
      cursor: pointer;
      padding: 8px;
      z-index: 101;
    }

    .hamburger span {
      width: 24px;
      height: 2px;
      background: var(--text-primary);
      transition: all 0.3s ease;
      border-radius: 2px;
    }

    .hamburger.active span:nth-child(1) {
      transform: rotate(45deg) translate(8px, 8px);
    }

    .hamburger.active span:nth-child(2) {
      opacity: 0;
    }

    .hamburger.active span:nth-child(3) {
      transform: rotate(-45deg) translate(7px, -7px);
    }

    @media (max-width: 768px) {
      nav {
        padding: 16px 24px;
        grid-template-columns: 1fr auto;
      }

      .hamburger {
        display: flex;
        justify-self: end;
      }

      .nav-links {
        position: fixed;
        top: 0;
        right: -100%;
        width: 280px;
        height: 100vh;
        background: var(--surface);
        flex-direction: column;
        padding: 80px 0 40px;
        border-left: 1px solid var(--border);
        transition: right 0.3s ease;
        overflow-y: auto;
      }

      .nav-links.active {
        right: 0;
      }

      .nav-item {
        border-left: none;
        border-right: none;
        border-bottom: 1px solid var(--border);
        padding: 20px 24px;
      }

      .nav-item:last-child {
        border-right: none;
      }
    }

    /* RIGHT PANEL */
    .right-panel {
      position: fixed;
      right: 20px;
      top: 16px;
      z-index: 200;
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 10px;
    }

    .location-pill {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 8px 14px;
      background: rgba(255, 255, 255, 0.06);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 12px;
      backdrop-filter: blur(16px);
    }

    .location-pill-text {
      display: flex;
      flex-direction: column;
    }

    .location-label {
      font-family: 'Switzer', Arial, sans-serif;
      font-size: 8px;
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .location-city {
      font-family: 'Switzer', Arial, sans-serif;
      font-size: 10px;
      color: var(--text-secondary);
      letter-spacing: 0.5px;
    }

    .time-display {
      font-family: 'Powergrotesk', Arial, sans-serif;
      font-size: 17px;
      font-weight: 500;
      color: var(--text-primary);
      letter-spacing: -0.5px;
    }

    .weather-icon {
      font-size: 14px;
      opacity: 0.8;
    }

    .social-links {
      display: flex;
      flex-direction: row;
      gap: 8px;
    }

    .social-links a {
      width: 40px;
      height: 40px;
      display: flex;
      align-items: center;
      justify-content: center;
      border: 1px solid rgba(255, 255, 255, 0.12);
      border-radius: 50%;
      color: var(--text-secondary);
      transition: border-color 0.2s, background 0.2s;
      background: rgba(255, 255, 255, 0.04);
      backdrop-filter: blur(10px);
    }

    .social-links a:hover {
      border-color: rgba(255, 255, 255, 0.3);
      background: rgba(255, 255, 255, 0.08);
    }

    .social-links a img {
      filter: brightness(0) saturate(100%) invert(71%) sepia(8%) saturate(579%) hue-rotate(355deg) brightness(90%) contrast(89%);
      transition: filter 0.2s;
    }

    .social-links a:hover img {
      filter: brightness(0) invert(1);
    }

    @media (max-width: 768px) {
      .right-panel {
        display: none;
      }
    }

    /* HERO */
    .hero {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      padding: 0 60px 60px;
      position: relative;
      background:
        radial-gradient(ellipse 90% 80% at 5% -5%, rgba(25, 45, 190, 0.55) 0%, transparent 55%),
        var(--bg);
    }

    .hero-content {
      position: relative;
      z-index: 2;
      text-align: center;
    }

    .hero h1 {
      font-family: 'Powergrotesk', Arial, sans-serif;
      font-size: clamp(60px, 11vw, 140px);
      font-weight: 500;
      line-height: 0.92;
      letter-spacing: -3px;
      color: var(--text-primary);
      text-align: center;
    }

    .hero h1 .typewriter {
      font-style: italic;
      color: var(--text-primary);
      border-right: 3px solid var(--text-primary);
      animation: blink 0.7s step-end infinite;
      display: inline-block;
      min-width: 13vw;
    }

    @keyframes blink { 50% { border-color: transparent; } }

    .hero-row {
      display: block;
      text-align: center;
      position: relative;
      overflow: visible;
    }

    .hero-photo {
      position: absolute;
      top: 12%;
      right: calc(50% - clamp(220px, 30vw, 450px));
      width: clamp(130px, 13vw, 185px);
      height: clamp(130px, 13vw, 185px);
      border-radius: 50%;
      object-fit: cover;
      object-position: top center;
      border: 2px solid rgba(255,255,255,0.08);
      z-index: 3;
    }

    .hero-desc {
      max-width: 400px;
      margin-top: 28px;
      margin-left: auto;
      margin-right: auto;
    }

    .hero-desc p {
      font-family: 'Switzer', Arial, sans-serif;
      font-size: 16px;
      font-weight: 300;
      color: var(--text-secondary);
      line-height: 1.6;
      text-align: center;
    }

    .hero-cta {
      margin-top: 36px;
      display: flex;
      gap: 16px;
      flex-wrap: wrap;
      justify-content: center;
    }

    .btn-primary {
      background: var(--accent);
      color: #fff;
      padding: 14px 28px;
      border-radius: 8px;
      font-family: 'Switzer', Arial, sans-serif;
      font-size: 14px;
      font-weight: 500;
      transition: opacity 0.2s;
    }

    .btn-primary:hover { opacity: 0.85; }

    .btn-outline {
      border: 1px solid var(--border);
      color: var(--text-primary);
      padding: 14px 28px;
      border-radius: 8px;
      font-family: 'Switzer', Arial, sans-serif;
      font-size: 14px;
      font-weight: 400;
      transition: border-color 0.2s;
    }

    .btn-outline:hover { border-color: var(--text-secondary); }

    /* QUOTE SECTION */
    .quote-section {
      padding: 80px 60px;
      border-top: 1px solid var(--border);
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 40px;
      align-items: center;
    }

    .quote-img {
      width: 100%;
      height: 400px;
      object-fit: cover;
      border-radius: 12px;
    }

    .quote-text {
      padding: 40px;
    }

    .quote-text blockquote {
      font-family: 'Powergrotesk', Arial, sans-serif;
      font-size: clamp(20px, 2.5vw, 32px);
      font-weight: 300;
      color: var(--text-primary);
      line-height: 1.4;
      margin-bottom: 20px;
    }

    .quote-text cite {
      font-family: 'Switzer', Arial, sans-serif;
      font-size: 13px;
      color: var(--text-secondary);
      font-style: normal;
    }

    /* ABOUT SECTION */
    .about-section {
      padding: 0 60px 80px;
      border-top: 1px solid var(--border);
      position: relative;
      overflow: hidden;
    }

    .about-decorative-text {
      font-family: 'Powergrotesk', Arial, sans-serif;
      font-size: clamp(120px, 22vw, 280px);
      font-weight: 500;
      color: var(--text-primary);
      opacity: 0.05;
      line-height: 1;
      letter-spacing: -8px;
      pointer-events: none;
      user-select: none;
      margin-left: -8px;
      margin-bottom: -40px;
      position: relative;
      z-index: 0;
    }

    .about-rows {
      position: relative;
      z-index: 1;
    }

    .about-row {
      display: grid;
      grid-template-columns: 100px 260px 1fr;
      gap: 40px;
      padding: 36px 0;
      border-top: 1px solid var(--border);
      align-items: start;
    }

    .about-number {
      font-family: 'Switzer', Arial, sans-serif;
      font-size: 13px;
      color: var(--text-secondary);
      padding-top: 6px;
    }

    .about-title {
      font-family: 'Powergrotesk', Arial, sans-serif;
      font-size: clamp(28px, 3vw, 40px);
      font-weight: 500;
      color: var(--text-primary);
      letter-spacing: -0.5px;
      line-height: 1.1;
    }

    .about-desc {
      font-family: 'Switzer', Arial, sans-serif;
      font-size: 15px;
      color: var(--text-secondary);
      line-height: 1.7;
      font-weight: 300;
      max-width: 520px;
      padding-top: 6px;
    }

    @media (max-width: 900px) {
      .about-row {
        grid-template-columns: 60px 1fr;
        grid-template-rows: auto auto;
        gap: 12px 20px;
      }
      .about-title { grid-column: 2; grid-row: 1; }
      .about-desc { grid-column: 1 / -1; grid-row: 2; padding-left: 80px; }
    }

    @media (max-width: 768px) {
      .about-section { padding: 0 24px 60px; }
      .about-decorative-text { font-size: clamp(80px, 20vw, 140px); letter-spacing: -4px; margin-bottom: -20px; }
      .about-row {
        grid-template-columns: 1fr;
        gap: 8px;
        padding: 24px 0;
      }
      .about-title { grid-column: 1; grid-row: auto; }
      .about-desc { grid-column: 1; grid-row: auto; padding-left: 0; }
    }

    /* CASE STUDIES */
    .case-studies {
      padding: 80px 60px;
      border-top: 1px solid var(--border);
    }

    .case-studies-heading {
      font-family: 'Powergrotesk', Arial, sans-serif;
      font-size: clamp(60px, 10vw, 120px);
      font-weight: 500;
      color: var(--text-primary);
      letter-spacing: -3px;
      line-height: 1;
      text-align: center;
      margin-bottom: 80px;
    }

    .section-label {
      font-family: 'Switzer', Arial, sans-serif;
      font-size: 12px;
      font-weight: 400;
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: 2px;
      margin-bottom: 48px;
    }

    .project-card {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 60px;
      padding: 60px 0;
      border-top: 1px solid var(--border);
      text-decoration: none;
      color: inherit;
      align-items: center;
      transition: opacity 0.25s;
    }

    .project-card:last-child { border-bottom: 1px solid var(--border); }
    .project-card:hover { opacity: 0.85; }

    .project-card-info {
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .project-card-name {
      font-family: 'Powergrotesk', Arial, sans-serif;
      font-size: clamp(32px, 4vw, 52px);
      font-weight: 500;
      color: var(--text-primary);
      letter-spacing: -1px;
      line-height: 1.05;
    }

    .project-card-tags {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }

    .project-tag {
      font-family: 'Switzer', Arial, sans-serif;
      font-size: 11px;
      font-weight: 400;
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: 1.5px;
    }

    .project-tag + .project-tag::before {
      content: '•';
      margin-right: 8px;
      opacity: 0.4;
    }

    .project-card-desc {
      font-family: 'Switzer', Arial, sans-serif;
      font-size: 15px;
      color: var(--text-secondary);
      line-height: 1.7;
      font-weight: 300;
      max-width: 420px;
    }

    .project-card-cta {
      font-family: 'Switzer', Arial, sans-serif;
      font-size: 14px;
      font-weight: 500;
      color: var(--accent);
      display: inline-flex;
      align-items: center;
      gap: 6px;
      margin-top: 8px;
      transition: gap 0.2s;
    }

    .project-card:hover .project-card-cta {
      gap: 12px;
    }

    .project-card-image {
      width: 100%;
      aspect-ratio: 16 / 10;
      object-fit: cover;
      border-radius: 12px;
      display: block;
    }

    @media (max-width: 768px) {
      .case-studies { padding: 40px 24px; }
      .case-studies-heading { font-size: clamp(40px, 12vw, 72px); letter-spacing: -2px; margin-bottom: 48px; }
      .project-card { grid-template-columns: 1fr; gap: 28px; padding: 40px 0; }
      .project-card-image { order: -1; }
    }

    /* BRANDS SECTION */
    .brands-section {
      padding: 80px 100px 80px 60px;
      border-top: 1px solid var(--border);
    }

    .brands-header {
      text-align: center;
      margin-bottom: 60px;
      max-width: 800px;
      margin-left: auto;
      margin-right: auto;
    }

    .brands-title {
      font-family: 'Powergrotesk', Arial, sans-serif;
      font-size: clamp(32px, 4vw, 48px);
      font-weight: 300;
      color: var(--text-primary);
      margin-bottom: 20px;
      letter-spacing: -1px;
    }

    .brands-subtitle {
      font-family: 'Switzer', Arial, sans-serif;
      font-size: 16px;
      color: var(--text-secondary);
      line-height: 1.6;
      font-weight: 300;
    }

    .brands-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      gap: 8px;
      align-items: stretch;
    }

    .brand-category {
      font-family: 'Switzer', Arial, sans-serif;
      font-size: 11px;
      color: var(--text-secondary);
      text-align: center;
      font-weight: 300;
      letter-spacing: 0.5px;
    }

    @media (max-width: 768px) {
      .brands-section {
        padding: 40px 24px;
      }

      .brands-grid {
        grid-template-columns: repeat(3, 1fr);
        gap: 8px;
      }

      .brand-item-full img {
        max-width: 80px;
        height: 28px;
      }
    }

    /* SERVICES */
    .services-section {
      padding: 80px 100px 80px 60px;
      border-top: 1px solid var(--border);
    }

    .services-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1px;
      background: var(--border);
      border: 1px solid var(--border);
      border-radius: 12px;
      overflow: hidden;
      margin-top: 48px;
    }

    .service-item {
      background: var(--bg);
      padding: 32px;
    }

    .service-icon {
      font-size: 24px;
      margin-bottom: 16px;
    }

    .service-item h3 {
      font-family: 'Powergrotesk', Arial, sans-serif;
      font-size: 18px;
      font-weight: 500;
      color: var(--text-primary);
      margin-bottom: 10px;
    }

    .service-item p {
      font-family: 'Switzer', Arial, sans-serif;
      font-size: 13px;
      color: var(--text-secondary);
      line-height: 1.6;
    }

    /* CONTACT */
    .contact-section {
      padding: 100px 60px;
      border-top: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 32px;
    }

    .contact-section h2 {
      font-family: 'Powergrotesk', Arial, sans-serif;
      font-size: clamp(40px, 8vw, 100px);
      font-weight: 300;
      color: var(--text-primary);
      letter-spacing: -2px;
      line-height: 0.95;
    }

    .contact-section h2 span {
      color: var(--accent);
      font-style: italic;
    }

    /* FOOTER */
    footer {
      padding: 32px 60px;
      border-top: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    footer p {
      font-family: 'Switzer', Arial, sans-serif;
      font-size: 13px;
      color: var(--text-secondary);
    }

    .footer-links {
      display: flex;
      gap: 24px;
    }

    .footer-links a {
      font-family: 'Switzer', Arial, sans-serif;
      font-size: 13px;
      color: var(--text-secondary);
      transition: color 0.2s;
    }

    .footer-links a:hover { color: var(--text-primary); }

    /* AVAILABILITY BADGE */
    .availability-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 6px 14px;
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 100px;
      font-family: 'Switzer', Arial, sans-serif;
      font-size: 12px;
      font-weight: 400;
      color: var(--text-secondary);
      margin-bottom: 28px;
    }
    .availability-dot {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: #4ade80;
      box-shadow: 0 0 0 0 rgba(74, 222, 128, 0.4);
      animation: pulse-dot 2s ease-out infinite;
    }
    @keyframes pulse-dot {
      0% { box-shadow: 0 0 0 0 rgba(74, 222, 128, 0.4); }
      70% { box-shadow: 0 0 0 8px rgba(74, 222, 128, 0); }
      100% { box-shadow: 0 0 0 0 rgba(74, 222, 128, 0); }
    }

    /* SCROLL ANIMATIONS */
    .fade-up {
      opacity: 0;
      transform: translateY(36px);
      transition: opacity 0.75s cubic-bezier(0.4, 0, 0.2, 1),
                  transform 0.75s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .fade-in {
      opacity: 0;
      transition: opacity 0.9s ease;
    }
    .fade-up.visible,
    .fade-in.visible {
      opacity: 1;
      transform: translateY(0);
    }
    .stagger-1 { transition-delay: 0.05s; }
    .stagger-2 { transition-delay: 0.15s; }
    .stagger-3 { transition-delay: 0.25s; }
    .stagger-4 { transition-delay: 0.35s; }
    .stagger-5 { transition-delay: 0.45s; }
