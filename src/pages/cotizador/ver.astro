---
// Client-facing quote viewer. Short links (?id=...) fetch the quote from
// /api/quotes (Supabase); old long links (#q=...) still work by decoding the
// quote from the URL hash directly, no backend needed.
// The comments panel also talks to a server (/api/comentarios) — it hides
// itself when that endpoint isn't configured.
// Not indexed, excluded from the sitemap.
import "../../styles/site.css";
import "../../styles/cotizador.css";
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Cotización — No Flag Brand</title>
    <meta name="robots" content="noindex, nofollow" />
    <meta name="theme-color" content="#0c1015" />
    <link rel="icon" type="image/png" href="/images/favicon.png" />

    <!-- Open Graph / Twitter: da tarjeta de preview al compartir el link por
         WhatsApp, Slack, etc. noindex arriba solo saca la página de buscadores
         — los crawlers de estas apps la leen igual para armar la tarjeta.
         El título/descripción son genéricos: la página es una sola build
         estática compartida por todas las cotizaciones (?id=... se resuelve
         en el navegador del cliente, no al momento de generar el HTML), así
         que no pueden variar por cliente sin una función server-side aparte. -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="No Flag Brand" />
    <meta property="og:title" content="Cotización — No Flag Brand" />
    <meta
      property="og:description"
      content="Revisa la propuesta y da seguimiento directo con No Flag Brand."
    />
    <meta property="og:url" content={new URL("/cotizador/ver", Astro.site)} />
    <meta property="og:image" content={new URL("/images/forms.png", Astro.site)} />
    <meta property="og:image:width" content="310" />
    <meta property="og:image:height" content="623" />
    <meta property="og:locale" content="es_MX" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Cotización — No Flag Brand" />
    <meta
      name="twitter:description"
      content="Revisa la propuesta y da seguimiento directo con No Flag Brand."
    />
    <meta name="twitter:image" content={new URL("/images/forms.png", Astro.site)} />
  </head>
  <body class="cz-body">
    <header class="cz-header" data-noprint="1">
      <span class="cz-header-brand">
        <img src="/images/noflagbrand-logo.svg" alt="No Flag Brand" class="cz-header-logo" />
        <span class="cz-header-tag" id="hdrTag">Cotización</span>
      </span>
      <div class="cz-header-actions">
        <button type="button" class="cz-btn cz-approve" id="btnApprove" hidden>Aprobar cotización</button>
        <button type="button" class="cz-btn ghost" id="btnPrint" hidden>Descargar PDF</button>
      </div>
    </header>

    <div class="cz-main">
      <main class="cz-doc-scroll" id="docScroll">
        <div class="cz-cover" id="czCover" hidden></div>
        <div class="cz-sheets" id="czPaper" hidden></div>
        <div class="cz-valor" id="czValor" hidden></div>
        <div class="cz-thanks" id="czThanks" hidden></div>
        <p class="cz-viewer-error" id="czError" hidden></p>
      </main>

      <!-- Comments panel: shown only once the quote decodes and the API
           answers, so a broken link or an unconfigured endpoint never shows
           the client a half-working form. -->
      <aside class="cz-comments" id="czComments" data-noprint="1" hidden>
        <div class="cz-comments-head">
          <span class="cz-label" id="cmTitle">Comentarios</span>
          <p class="cz-hint" id="cmHint"></p>
        </div>
        <div class="cz-comments-list" id="cmList"></div>
        <form class="cz-comments-form" id="cmForm">
          <input class="cz-input" id="cmAutor" placeholder="Tu nombre" autocomplete="name" />
          <textarea class="cz-textarea cz-comments-textarea" id="cmTexto" maxlength="2000"></textarea>
          <div class="cz-error" id="cmError" hidden></div>
          <button type="submit" class="cz-btn" id="cmSend">Enviar comentario</button>
        </form>
      </aside>
    </div>

    <div class="cz-toast" id="czToast" role="status"></div>

    <script>
      import {
        LABELS,
        labelsFor,
        decodeQuote,
        renderDoc,
        renderCover,
        renderValor,
        renderThanks,
      } from "../../lib/cotizador.js";
      import {
        fetchComentarios,
        postComentario,
        renderComentarios,
      } from "../../lib/cotizador-comentarios.js";
      import { fetchQuoteRemote } from "../../lib/cotizador-quotes-store.js";

      // Vanilla-DOM page: `any` casts keep strict TS out of plain JS access.
      const $ = (id: string) => document.getElementById(id) as any;
      const paper = $("czPaper");
      const cover = $("czCover");
      const valorSheet = $("czValor");
      const thanksSheet = $("czThanks");
      const errorBox = $("czError");
      const btnPrint = $("btnPrint");
      const btnApprove = $("btnApprove");
      const hdrTag = $("hdrTag");
      const panel = $("czComments");

      // The client's name is remembered so a second comment doesn't ask again.
      const AUTOR_KEY = "cz-comment-autor";
      // Approval state per quote, so on revisits the button stays "Aprobada ✓".
      const approvedKey = (data: any) => `cz-approved:${data.id || data.meta.numero || "q"}`;

      function fail() {
        errorBox.textContent = labelsFor(document.documentElement.lang).linkInvalido;
        errorBox.hidden = false;
        paper.hidden = true;
        cover.hidden = true;
        valorSheet.hidden = true;
        thanksSheet.hidden = true;
        btnPrint.hidden = true;
        btnApprove.hidden = true;
        panel.hidden = true;
      }

      async function load() {
        const id = new URLSearchParams(location.search).get("id");
        let data;
        if (id) {
          // Short link: the quote lives in Supabase, keyed by `id`.
          try {
            data = await fetchQuoteRemote(id);
          } catch (e) {
            return fail();
          }
        } else {
          // Old long link: the quote travels encoded in the URL hash.
          const match = location.hash.match(/^#q=(.+)$/);
          if (!match) return fail();
          try {
            data = await decodeQuote(match[1]);
          } catch (e) {
            return fail();
          }
        }
        if (!data || !data.q || !data.meta) return fail();

        const t = labelsFor(data.lang);
        document.documentElement.lang = data.lang === "en" ? "en" : "es";
        document.title = `${t.cotizacion} ${data.meta.numero || ""} — No Flag Brand`.trim();
        hdrTag.textContent = `${t.cotizacion} ${data.meta.numero || ""}`.trim();

        renderCover(cover, data);
        renderDoc(paper, data, { editable: false });
        // renderValor manages its own hidden state: old quotes without
        // beneficios simply don't show the closing sheet.
        renderValor(valorSheet, data, { editable: false });
        renderThanks(thanksSheet, data, { editable: false });
        cover.hidden = false;
        paper.hidden = false;
        errorBox.hidden = true;

        btnPrint.textContent = t.descargar;
        btnPrint.hidden = false;

        // Approve button: reset (load() re-runs on hashchange) and restore a
        // previous approval from this browser; comments may confirm it later.
        btnApprove.classList.remove("is-approved", "is-pop");
        btnApprove.disabled = false;
        btnApprove.textContent = t.aprobar;
        btnApprove.hidden = false;
        let stored = null;
        try {
          stored = localStorage.getItem(approvedKey(data));
        } catch (err) {}
        if (stored) markApproved(data);

        initReveals();
        setupComments(data);
      }

      /* ---------- Entrance & scroll reveals ---------- */
      // Portada con entrada escalonada al abrir y bloques del documento
      // apareciendo al hacer scroll (estilos en cotizador.css, sección
      // "Viewer entrance"). Solo el visor las activa: sin JS, sin la clase
      // `cz-animate` ni los `cz-rv`, todo se ve normal.
      let revealObserver: any = null;

      function initReveals() {
        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
        if (typeof IntersectionObserver === "undefined") return;
        document.body.classList.add("cz-animate");
        // load() puede correr de nuevo (hashchange): soltar los nodos viejos.
        if (revealObserver) revealObserver.disconnect();

        const targets = document.querySelectorAll(
          [
            ".cz-paper .cz-doc-top",
            ".cz-paper .cz-doc-prep",
            ".cz-paper .cz-doc-h1",
            ".cz-paper .cz-cont-head",
            ".cz-paper .cz-sec",
            ".cz-paper .cz-terms-col",
            ".cz-paper .cz-doc-vigencia",
            ".cz-paper .cz-doc-foot",
            ".cz-valor > *",
            ".cz-thanks-logo",
            ".cz-thanks-body",
            ".cz-thanks-foot",
          ].join(", ")
        );

        revealObserver = new IntersectionObserver(
          (entries: any[]) => {
            // Los que entran juntos al viewport se escalonan entre sí; uno
            // que entra solo (scroll lento) aparece sin espera extra.
            let batch = 0;
            for (const entry of entries) {
              if (!entry.isIntersecting) continue;
              entry.target.style.transitionDelay = `${batch * 90}ms`;
              entry.target.classList.add("is-in");
              revealObserver.unobserve(entry.target);
              batch++;
            }
          },
          { rootMargin: "0px 0px -10% 0px", threshold: 0.05 }
        );

        // Lo que ya está en el primer viewport se revela de inmediato (con
        // cascada), sin esperar al observer.
        const vh = window.innerHeight;
        let initial = 0;
        for (const node of targets) {
          node.classList.add("cz-rv");
          const r = node.getBoundingClientRect();
          if (r.top < vh * 0.9 && r.bottom > 0) {
            (node as any).style.transitionDelay = `${initial * 90}ms`;
            node.classList.add("is-in");
            initial++;
          } else {
            revealObserver.observe(node);
          }
        }

        // Seguro: si IntersectionObserver existe pero nunca entrega callbacks
        // (webviews con throttling agresivo), revelar todo — mejor perder la
        // animación que dejar la cotización invisible. El sentinel observa
        // el body (siempre intersecta): si IO vive, dispara al instante y el
        // timeout no hace nada.
        let ioAlive = false;
        const sentinel = new IntersectionObserver(() => {
          ioAlive = true;
          sentinel.disconnect();
        });
        sentinel.observe(document.body);
        setTimeout(() => {
          if (ioAlive) return;
          revealObserver.disconnect();
          for (const node of document.querySelectorAll(".cz-rv, .cz-timeline")) {
            node.classList.add("is-in");
          }
        }, 1600);
      }

      /* ---------- Comments ---------- */
      let current: any = null;
      let sending = false;
      let toastTimer: ReturnType<typeof setTimeout>;

      function toast(msg: string) {
        const node = $("czToast");
        node.textContent = msg;
        node.classList.add("is-visible");
        clearTimeout(toastTimer);
        toastTimer = setTimeout(() => node.classList.remove("is-visible"), 2600);
      }

      function paint(comentarios: any[]) {
        const t = labelsFor(current.lang);
        renderComentarios($("cmList"), comentarios, {
          lang: current.lang,
          vacio: t.sinComentariosCliente,
          anon: t.anonimo,
        });
      }

      async function setupComments(data: any) {
        current = data;
        const t = labelsFor(data.lang);
        $("cmTitle").textContent = t.comentarios;
        $("cmHint").textContent = t.comentariosHint;
        $("cmAutor").placeholder = t.phAutor;
        $("cmAutor").setAttribute("aria-label", t.phAutor);
        $("cmTexto").placeholder = t.phComentario;
        $("cmTexto").setAttribute("aria-label", t.comentarios);
        $("cmSend").textContent = t.enviarComentario;
        $("cmAutor").value =
          $("cmAutor").value || localStorage.getItem(AUTOR_KEY) || data.meta.nombre || "";

        try {
          const comentarios = await fetchComentarios(data.id);
          paint(comentarios);
          panel.hidden = false;
          // Una aprobación hecha desde otro dispositivo viaja como comentario
          // marcado: si está en el hilo, el botón ya llega en "Aprobada ✓".
          if (comentarios.some(esAprobacion)) markApproved(data);
        } catch (e) {
          // Comentarios apagados o caídos: el cliente ve la cotización
          // completa igual, que es lo que vino a hacer.
          panel.hidden = true;
        }
      }

      $("cmForm").addEventListener("submit", async (e: any) => {
        e.preventDefault();
        if (sending || !current) return;
        const t = labelsFor(current.lang);
        const errBox = $("cmError");
        errBox.hidden = true;

        const texto = $("cmTexto").value.trim();
        if (!texto) {
          errBox.textContent = t.errComentarioVacio;
          errBox.hidden = false;
          $("cmTexto").focus();
          return;
        }

        const autor = $("cmAutor").value.trim();
        sending = true;
        $("cmSend").disabled = true;
        $("cmSend").textContent = t.enviandoComentario;
        try {
          await postComentario({
            quote: current.id,
            autor,
            texto,
            numero: current.meta.numero || "",
            cliente: [current.meta.nombre, current.meta.empresa].filter(Boolean).join(" · "),
          });
          try {
            localStorage.setItem(AUTOR_KEY, autor);
          } catch (err) {}
          $("cmTexto").value = "";
          // Re-fetch instead of appending: así el cliente ve el hilo real,
          // incluidos comentarios de otra sesión o de otro dispositivo.
          paint(await fetchComentarios(current.id));
          toast(t.comentarioEnviado);
        } catch (err) {
          errBox.textContent = t.errComentario;
          errBox.hidden = false;
        } finally {
          sending = false;
          $("cmSend").disabled = false;
          $("cmSend").textContent = t.enviarComentario;
        }
      });

      /* ---------- Aprobación ---------- */
      // El texto del comentario de aprobación es fijo por idioma: sirve de
      // marca para reconocer una cotización ya aprobada al volver a abrirla.
      function esAprobacion(c: any) {
        return (
          typeof c.texto === "string" &&
          (c.texto.startsWith(LABELS.es.aprobadaComentario) ||
            c.texto.startsWith(LABELS.en.aprobadaComentario))
        );
      }

      function markApproved(data: any) {
        btnApprove.disabled = true;
        btnApprove.classList.add("is-approved");
        btnApprove.textContent = labelsFor(data.lang).aprobada;
        try {
          localStorage.setItem(approvedKey(data), "1");
        } catch (err) {}
      }

      btnApprove.addEventListener("click", async () => {
        if (!current || btnApprove.disabled) return;
        const t = labelsFor(current.lang);
        markApproved(current);
        btnApprove.classList.add("is-pop");
        confettiBurst(btnApprove);
        toast(t.aprobadaToast);

        // Avisar a No Flag Brand vía el hilo de comentarios. Si el endpoint
        // está apagado la fiesta local ya pasó y el estado quedó guardado.
        if (panel.hidden) return;
        try {
          const autor = $("cmAutor").value.trim() || current.meta.nombre || "";
          await postComentario({
            quote: current.id,
            autor,
            texto: t.aprobadaComentario,
            numero: current.meta.numero || "",
            cliente: [current.meta.nombre, current.meta.empresa].filter(Boolean).join(" · "),
          });
          paint(await fetchComentarios(current.id));
        } catch (err) {}
      });

      // Confeti casero sobre un canvas de una sola vida: explota desde el
      // botón, cae con gravedad y el canvas se quita solo al terminar.
      function confettiBurst(origin: any) {
        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
        const canvas = document.createElement("canvas");
        canvas.className = "cz-confetti";
        const dpr = window.devicePixelRatio || 1;
        canvas.width = window.innerWidth * dpr;
        canvas.height = window.innerHeight * dpr;
        const ctx = canvas.getContext("2d");
        if (!ctx) return;
        ctx.scale(dpr, dpr);
        document.body.appendChild(canvas);

        const rect = origin.getBoundingClientRect();
        const cx = rect.left + rect.width / 2;
        const cy = rect.top + rect.height / 2;
        const colors = ["#d8482b", "#e8a33d", "#dfe6f5", "#d4d2cf", "#6fcf97"];
        const parts: any[] = [];
        for (let i = 0; i < 160; i++) {
          const angle = Math.random() * Math.PI * 2;
          const speed = 3 + Math.random() * 9;
          parts.push({
            x: cx,
            y: cy,
            vx: Math.cos(angle) * speed,
            vy: Math.sin(angle) * speed - 5,
            w: 4 + Math.random() * 5,
            h: 7 + Math.random() * 6,
            rot: Math.random() * Math.PI,
            vr: (Math.random() - 0.5) * 0.3,
            color: colors[i % colors.length],
            life: 0,
            ttl: 110 + Math.random() * 70,
          });
        }

        // Vida por frames + tope en tiempo real: en pestañas con rAF
        // acelerado o estrangulado el canvas igual se retira solo.
        const started = performance.now();
        function frame() {
          if (performance.now() - started > 6000) return canvas.remove();
          ctx.clearRect(0, 0, window.innerWidth, window.innerHeight);
          let alive = 0;
          for (const p of parts) {
            p.life++;
            if (p.life > p.ttl) continue;
            p.vy += 0.16;
            p.vx *= 0.99;
            p.x += p.vx;
            p.y += p.vy;
            p.rot += p.vr;
            ctx.globalAlpha = Math.max(0, 1 - p.life / p.ttl);
            ctx.save();
            ctx.translate(p.x, p.y);
            ctx.rotate(p.rot);
            ctx.fillStyle = p.color;
            ctx.fillRect(-p.w / 2, -p.h / 2, p.w, p.h);
            ctx.restore();
            alive++;
          }
          if (alive) requestAnimationFrame(frame);
          else canvas.remove();
        }
        requestAnimationFrame(frame);
      }

      btnPrint.addEventListener("click", () => window.print());
      window.addEventListener("hashchange", load);
      load();
    </script>
  </body>
</html>
