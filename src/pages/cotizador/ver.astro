---
// Client-facing quote viewer. Short links (?id=...) fetch the quote from
// /api/quotes (Supabase); old long links (#q=...) still work by decoding the
// quote from the URL hash directly, no backend needed.
// The comments panel also talks to a server (/api/comentarios) — it hides
// itself when that endpoint isn't configured.
// Not indexed, excluded from the sitemap.
import "../../styles/site.css";
import "../../styles/cotizador.css";
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Cotización — No Flag Brand</title>
    <meta name="robots" content="noindex, nofollow" />
    <meta name="theme-color" content="#0c1015" />
    <link rel="icon" type="image/png" href="/images/favicon.png" />
  </head>
  <body class="cz-body">
    <header class="cz-header" data-noprint="1">
      <span class="cz-header-brand">
        <img src="/images/noflagbrand-logo.svg" alt="No Flag Brand" class="cz-header-logo" />
        <span class="cz-header-tag" id="hdrTag">Cotización</span>
      </span>
      <div class="cz-header-actions">
        <button type="button" class="cz-btn" id="btnPrint" hidden>Descargar PDF</button>
      </div>
    </header>

    <div class="cz-main">
      <main class="cz-doc-scroll" id="docScroll">
        <div class="cz-cover" id="czCover" hidden></div>
        <div class="cz-paper" id="czPaper" hidden></div>
        <p class="cz-viewer-error" id="czError" hidden></p>
      </main>

      <!-- Comments panel: shown only once the quote decodes and the API
           answers, so a broken link or an unconfigured endpoint never shows
           the client a half-working form. -->
      <aside class="cz-comments" id="czComments" data-noprint="1" hidden>
        <div class="cz-comments-head">
          <span class="cz-label" id="cmTitle">Comentarios</span>
          <p class="cz-hint" id="cmHint"></p>
        </div>
        <div class="cz-comments-list" id="cmList"></div>
        <form class="cz-comments-form" id="cmForm">
          <input class="cz-input" id="cmAutor" placeholder="Tu nombre" autocomplete="name" />
          <textarea class="cz-textarea cz-comments-textarea" id="cmTexto" maxlength="2000"></textarea>
          <div class="cz-error" id="cmError" hidden></div>
          <button type="submit" class="cz-btn" id="cmSend">Enviar comentario</button>
        </form>
      </aside>
    </div>

    <div class="cz-toast" id="czToast" role="status"></div>

    <script>
      import { labelsFor, decodeQuote, renderDoc, renderCover } from "../../lib/cotizador.js";
      import {
        fetchComentarios,
        postComentario,
        renderComentarios,
      } from "../../lib/cotizador-comentarios.js";
      import { fetchQuoteRemote } from "../../lib/cotizador-quotes-store.js";

      // Vanilla-DOM page: `any` casts keep strict TS out of plain JS access.
      const $ = (id: string) => document.getElementById(id) as any;
      const paper = $("czPaper");
      const cover = $("czCover");
      const errorBox = $("czError");
      const btnPrint = $("btnPrint");
      const hdrTag = $("hdrTag");
      const panel = $("czComments");

      // The client's name is remembered so a second comment doesn't ask again.
      const AUTOR_KEY = "cz-comment-autor";

      function fail() {
        errorBox.textContent = labelsFor(document.documentElement.lang).linkInvalido;
        errorBox.hidden = false;
        paper.hidden = true;
        cover.hidden = true;
        btnPrint.hidden = true;
        panel.hidden = true;
      }

      async function load() {
        const id = new URLSearchParams(location.search).get("id");
        let data;
        if (id) {
          // Short link: the quote lives in Supabase, keyed by `id`.
          try {
            data = await fetchQuoteRemote(id);
          } catch (e) {
            return fail();
          }
        } else {
          // Old long link: the quote travels encoded in the URL hash.
          const match = location.hash.match(/^#q=(.+)$/);
          if (!match) return fail();
          try {
            data = await decodeQuote(match[1]);
          } catch (e) {
            return fail();
          }
        }
        if (!data || !data.q || !data.meta) return fail();

        const t = labelsFor(data.lang);
        document.documentElement.lang = data.lang === "en" ? "en" : "es";
        document.title = `${t.cotizacion} ${data.meta.numero || ""} — No Flag Brand`.trim();
        hdrTag.textContent = `${t.cotizacion} ${data.meta.numero || ""}`.trim();

        renderCover(cover, data);
        renderDoc(paper, data, { editable: false });
        cover.hidden = false;
        paper.hidden = false;
        errorBox.hidden = true;

        btnPrint.textContent = t.descargar;
        btnPrint.hidden = false;

        setupComments(data);
      }

      /* ---------- Comments ---------- */
      let current: any = null;
      let sending = false;
      let toastTimer: ReturnType<typeof setTimeout>;

      function toast(msg: string) {
        const node = $("czToast");
        node.textContent = msg;
        node.classList.add("is-visible");
        clearTimeout(toastTimer);
        toastTimer = setTimeout(() => node.classList.remove("is-visible"), 2600);
      }

      function paint(comentarios: any[]) {
        const t = labelsFor(current.lang);
        renderComentarios($("cmList"), comentarios, {
          lang: current.lang,
          vacio: t.sinComentariosCliente,
          anon: t.anonimo,
        });
      }

      async function setupComments(data: any) {
        current = data;
        const t = labelsFor(data.lang);
        $("cmTitle").textContent = t.comentarios;
        $("cmHint").textContent = t.comentariosHint;
        $("cmAutor").placeholder = t.phAutor;
        $("cmAutor").setAttribute("aria-label", t.phAutor);
        $("cmTexto").placeholder = t.phComentario;
        $("cmTexto").setAttribute("aria-label", t.comentarios);
        $("cmSend").textContent = t.enviarComentario;
        $("cmAutor").value =
          $("cmAutor").value || localStorage.getItem(AUTOR_KEY) || data.meta.nombre || "";

        try {
          paint(await fetchComentarios(data.id));
          panel.hidden = false;
        } catch (e) {
          // Comentarios apagados o caídos: el cliente ve la cotización
          // completa igual, que es lo que vino a hacer.
          panel.hidden = true;
        }
      }

      $("cmForm").addEventListener("submit", async (e: any) => {
        e.preventDefault();
        if (sending || !current) return;
        const t = labelsFor(current.lang);
        const errBox = $("cmError");
        errBox.hidden = true;

        const texto = $("cmTexto").value.trim();
        if (!texto) {
          errBox.textContent = t.errComentarioVacio;
          errBox.hidden = false;
          $("cmTexto").focus();
          return;
        }

        const autor = $("cmAutor").value.trim();
        sending = true;
        $("cmSend").disabled = true;
        $("cmSend").textContent = t.enviandoComentario;
        try {
          await postComentario({
            quote: current.id,
            autor,
            texto,
            numero: current.meta.numero || "",
            cliente: [current.meta.nombre, current.meta.empresa].filter(Boolean).join(" · "),
          });
          try {
            localStorage.setItem(AUTOR_KEY, autor);
          } catch (err) {}
          $("cmTexto").value = "";
          // Re-fetch instead of appending: así el cliente ve el hilo real,
          // incluidos comentarios de otra sesión o de otro dispositivo.
          paint(await fetchComentarios(current.id));
          toast(t.comentarioEnviado);
        } catch (err) {
          errBox.textContent = t.errComentario;
          errBox.hidden = false;
        } finally {
          sending = false;
          $("cmSend").disabled = false;
          $("cmSend").textContent = t.enviarComentario;
        }
      });

      btnPrint.addEventListener("click", () => window.print());
      window.addEventListener("hashchange", load);
      load();
    </script>
  </body>
</html>
