---
// Private quote builder (No Flag Brand). Access is gated by a key checked
// client-side (SHA-256); quotes are built here and shared with clients as a
// self-contained link to /cotizador/ver. Not indexed and excluded from the
// sitemap — this page is a tool, not site content.
import "../../styles/site.css";
import "../../styles/cotizador.css";
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Cotizador — No Flag Brand</title>
    <meta name="robots" content="noindex, nofollow" />
    <meta name="theme-color" content="#0c1015" />
    <link rel="icon" type="image/png" href="/images/favicon.png" />
  </head>
  <body class="cz-body">
    <!-- Access gate -->
    <div class="cz-gate" id="czGate">
      <form class="cz-gate-card" id="czGateForm">
        <img src="/images/noflagbrand-logo.svg" alt="No Flag Brand" class="cz-gate-logo" />
        <div>
          <h1 class="cz-gate-title" id="gateTitle">Acceso privado</h1>
          <p class="cz-gate-text" id="gateText">Escribe la clave para entrar al cotizador.</p>
        </div>
        <input
          type="password"
          class="cz-input"
          id="gateInput"
          placeholder="Clave"
          aria-label="Clave de acceso"
          autocomplete="current-password"
          autofocus
        />
        <div class="cz-gate-error" id="gateError"></div>
        <button type="submit" class="cz-btn" id="gateSubmit">Entrar</button>
      </form>
    </div>

    <!-- Builder -->
    <div id="czApp" hidden>
      <header class="cz-header" data-noprint="1">
        <a class="cz-header-brand" href="/">
          <img src="/images/noflagbrand-logo.svg" alt="No Flag Brand" class="cz-header-logo" />
          <span class="cz-header-tag" id="hdrTag">Cotizador</span>
        </a>
        <div class="cz-header-actions">
          <div class="cz-lang" role="group" aria-label="Idioma">
            <button type="button" data-lang="es" id="langEs">ES</button>
            <button type="button" data-lang="en" id="langEn">EN</button>
          </div>
          <button type="button" class="cz-btn ghost" id="btnComments" hidden>Comentarios</button>
          <button type="button" class="cz-btn ghost" id="btnList">
            <span id="btnListLabel">Cotizaciones</span>
            <span class="cz-badge" id="btnListCount">0</span>
          </button>
          <button type="button" class="cz-btn" id="btnNew">Nueva cotización</button>
        </div>
      </header>

      <!-- Saved quotes drawer -->
      <div class="cz-drawer-backdrop" id="drawerBackdrop" hidden></div>
      <aside class="cz-drawer" id="czDrawer" hidden aria-label="Cotizaciones guardadas">
        <div class="cz-drawer-head">
          <span class="cz-label" id="drawerTitle">Cotizaciones</span>
          <button type="button" class="cz-drawer-close" id="btnDrawerClose" aria-label="Cerrar">×</button>
        </div>
        <!-- Filtros por estado. `aria-pressed` marca la pill activa; el JS
             re-pinta la lista al cambiar. -->
        <div class="cz-filtros" id="drawerFiltros" role="group" aria-label="Filtrar cotizaciones">
          <button type="button" class="cz-pill is-active" data-filtro="todas" aria-pressed="true">Todas</button>
          <button type="button" class="cz-pill" data-filtro="aprobadas" aria-pressed="false">Aprobadas</button>
          <button type="button" class="cz-pill" data-filtro="rechazadas" aria-pressed="false">Rechazadas</button>
        </div>
        <div class="cz-drawer-list" id="drawerList"></div>
        <button type="button" class="cz-btn" id="btnDrawerNew">Nueva cotización</button>
      </aside>

      <div class="cz-main">
        <aside class="cz-sidebar" data-noprint="1">
          <!-- Cotización abierta: número + proyecto, para no perder el hilo
               al navegar entre cotizaciones guardadas. -->
          <div class="cz-current">
            <span class="cz-current-num" id="curNumero"></span>
            <span class="cz-current-title" id="curTitulo"></span>
          </div>

          <div class="cz-group">
            <div class="cz-label" id="lblCliente">Datos del cliente</div>
            <input class="cz-input" id="inNombre" data-key="nombre" placeholder="Nombre del cliente" />
            <input class="cz-input" id="inEmpresa" data-key="empresa" placeholder="Empresa" />
            <input class="cz-input" id="inContacto" data-key="contacto" placeholder="Correo o teléfono" />
            <div class="cz-row-2">
              <input class="cz-input" id="inNumero" data-key="numero" placeholder="Nº" />
              <input class="cz-input" id="inFecha" data-key="fecha" placeholder="Fecha" />
            </div>
          </div>

          <div class="cz-group">
            <div class="cz-label" id="lblContexto">Contexto del proyecto</div>
            <textarea class="cz-textarea" id="inCtx"></textarea>
            <div class="cz-rate-row">
              <span id="lblTarifa">Tarifa base</span>
              <input class="cz-input" id="inRate" inputmode="decimal" />
              <span>/h</span>
              <select class="cz-select" id="inMoneda" aria-label="Moneda">
                <option value="USD">USD</option>
                <option value="MXN">MXN</option>
                <option value="EUR">EUR</option>
              </select>
            </div>
            <div class="cz-deadline-row">
              <span id="lblDeadline">Fecha límite</span>
              <input type="date" class="cz-input" id="inDeadline" aria-label="Fecha límite" />
            </div>
            <div style="display: flex; flex-direction: column; gap: 6px;">
              <input type="password" class="cz-input" id="inApiKey" placeholder="Groq API key (gsk_…)" autocomplete="off" />
              <div class="cz-hint" id="hintApi">Se guarda solo en este navegador. Créala gratis en console.groq.com/keys</div>
            </div>
            <!-- Antes de generar: solo "Generar propuesta". Ya generada: el
                 primario pasa a "Guardar cambios" y abajo queda el terciario
                 "Regenerar propuesta" (usa el contexto actualizado). -->
            <button type="button" class="cz-btn" id="btnGenerate">Generar propuesta</button>
            <button type="button" class="cz-btn" id="btnSave" hidden>Guardar cambios</button>
            <button type="button" class="cz-btn-text" id="btnRegen" hidden>Regenerar propuesta</button>
            <div class="cz-error" id="genError" hidden></div>
            <div class="cz-hint" id="hintGen"></div>
          </div>

          <!-- Copiar link / PDF solo tienen sentido con una propuesta ya
               generada; antes de eso el grupo entero va oculto. -->
          <div class="cz-group cz-sidebar-actions" id="sidebarActions" hidden>
            <button type="button" class="cz-btn ghost" id="btnCopy">Copiar link para cliente</button>
            <button type="button" class="cz-btn ghost" id="btnPrint">Descargar PDF</button>
          </div>

          <!-- Aprobación: su propia fila para que se lea completa. Aparece solo
               cuando el endpoint de comentarios responde (la aprobación vive en
               ese hilo). Sin aprobar → botón "Aprobar cotización"; aprobada →
               sello verde evidente + acción para eliminar la aprobación. -->
          <div class="cz-group cz-aprobacion-group" id="aprobacionGroup" hidden>
            <div class="cz-estado-ctas" id="estadoCtas">
              <button type="button" class="cz-btn cz-approve-cta" id="btnAprobar">Aprobar cotización</button>
              <button type="button" class="cz-btn cz-reject-cta" id="btnRechazar">Marcar como rechazada</button>
            </div>
            <div class="cz-aprobada-sello" id="aprobadaSello" hidden>
              <span class="cz-aprobada-tag">
                <svg class="cz-check" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                <span id="aprobadaTagText">Aprobada</span>
              </span>
              <button type="button" class="cz-aprobada-quitar" id="btnQuitarAprobacion">Eliminar aprobación</button>
            </div>
            <div class="cz-rechazada-sello" id="rechazadaSello" hidden>
              <span class="cz-rechazada-tag">
                <svg class="cz-x" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" /></svg>
                <span id="rechazadaTagText">Rechazada</span>
              </span>
              <button type="button" class="cz-aprobada-quitar" id="btnQuitarRechazo">Quitar rechazo</button>
            </div>
          </div>
        </aside>

        <main class="cz-doc-scroll">
          <div class="cz-cover" id="czCover"></div>
          <div class="cz-sheets" id="czPaper"></div>
          <div class="cz-valor" id="czValor"></div>
          <div class="cz-thanks" id="czThanks"></div>
        </main>

        <!-- Comentarios del cliente sobre la cotización abierta. Solo lectura:
             el hilo es el canal del cliente hacia acá, no una conversación. -->
        <aside class="cz-comments" id="czComments" data-noprint="1" hidden>
          <div class="cz-comments-head">
            <span class="cz-label" id="cmTitle">Comentarios</span>
            <button type="button" class="cz-drawer-close" id="btnCommentsClose" aria-label="Cerrar">×</button>
          </div>
          <div class="cz-comments-list" id="cmList"></div>
        </aside>
      </div>
    </div>

    <div class="cz-toast" id="czToast" role="status"></div>

    <!-- Confirmación de borrado: modal con sus botones en vez del confirm de
         dos clics dentro de la tarjeta del drawer. -->
    <div class="cz-modal-backdrop" id="delBackdrop" hidden>
      <div class="cz-modal" role="dialog" aria-modal="true" aria-labelledby="delTitle">
        <h2 class="cz-modal-title" id="delTitle">¿Eliminar esta cotización?</h2>
        <p class="cz-modal-quote" id="delQuote"></p>
        <p class="cz-modal-text" id="delText"></p>
        <div class="cz-modal-actions">
          <button type="button" class="cz-btn ghost" id="delCancel">Cancelar</button>
          <button type="button" class="cz-btn" id="delConfirm">Sí, eliminar</button>
        </div>
      </div>
    </div>

    <script>
      import {
        labelsFor,
        defaultQuote,
        renderDoc,
        renderCover,
        renderValor,
        renderThanks,
        encodeQuote,
        quoteSlug,
        generateProposal,
        genId,
        nextNumero,
        todayStr,
        fmtMoney,
        totalOf,
      } from "../../lib/cotizador.js";
      import {
        fetchComentarios,
        postComentario,
        renderComentarios,
        esAprobacion,
        esRechazo,
        deleteAprobacion,
      } from "../../lib/cotizador-comentarios.js";
      import { saveQuoteRemote, deleteQuoteRemote } from "../../lib/cotizador-quotes-store.js";

      // To change the access key: run in any browser console —
      //   crypto.subtle.digest('SHA-256', new TextEncoder().encode('nueva-clave'))
      //     .then(b => console.log([...new Uint8Array(b)].map(x => x.toString(16).padStart(2, '0')).join('')))
      // and paste the result here.
      const PASS_HASH = "f79decdec52ec63f49c7d217d4cc846ecb447c962368c068956dcbf038b03dad";
      const AUTH_KEY = "cz-auth-v1";
      const LEGACY_DRAFT_KEY = "cz-quote-v1";
      const QUOTES_KEY = "cz-quotes-v1";
      const CURRENT_KEY = "cz-current-id";
      const CTX_KEY = "cz-ctx-v1";
      const GROQ_KEY = "cz-groq-key";

      // Vanilla-DOM tool page: the cast to `any` keeps strict TS (astro
      // check) out of the way of plain JS element access.
      const $ = (id: string) => document.getElementById(id) as any;

      async function sha256hex(text: string) {
        const buf = await crypto.subtle.digest("SHA-256", new TextEncoder().encode(text));
        return [...new Uint8Array(buf)].map((b) => b.toString(16).padStart(2, "0")).join("");
      }

      /* ---------- State ---------- */
      // All quotes live in one localStorage collection; `data` is the one
      // currently open in the editor and autosaves into the collection on
      // every change.
      let quotes: any[] = [];
      try {
        const saved = JSON.parse(localStorage.getItem(QUOTES_KEY) || "null");
        if (Array.isArray(saved)) quotes = saved.filter((q) => q && q.q && q.meta);
      } catch (e) {}

      // Migrate the single-draft storage from the first version of the tool.
      try {
        const legacy = JSON.parse(localStorage.getItem(LEGACY_DRAFT_KEY) || "null");
        if (legacy && legacy.q && legacy.meta && !quotes.length) {
          legacy.id = legacy.id || genId();
          legacy.updatedAt = Date.now();
          quotes.push(legacy);
          localStorage.setItem(QUOTES_KEY, JSON.stringify(quotes));
          localStorage.setItem(CURRENT_KEY, legacy.id);
        }
        localStorage.removeItem(LEGACY_DRAFT_KEY);
      } catch (e) {}

      // Compat: cotizaciones guardadas antes del flag `generado` se tratan
      // como generadas (sus botones de link/PDF siempre estuvieron visibles).
      quotes.forEach((q) => {
        if (typeof q.generado === "undefined") q.generado = true;
      });

      let data =
        quotes.find((q) => q.id === localStorage.getItem(CURRENT_KEY)) ||
        quotes[quotes.length - 1] ||
        defaultQuote("es");
      if (!data.id) data.id = genId();
      // Una cotización recién creada (default) aún no tiene propuesta generada.
      if (typeof data.generado === "undefined") data.generado = false;

      // Migra el contexto global (una sola caja compartida por todas) a
      // contexto por cotización: la abierta hereda el texto viejo una vez.
      try {
        const legacyCtx = localStorage.getItem(CTX_KEY);
        if (legacyCtx !== null) {
          if (typeof data.ctx === "undefined") data.ctx = legacyCtx;
          localStorage.removeItem(CTX_KEY);
        }
      } catch (e) {}
      quotes.forEach((q) => {
        if (typeof q.ctx === "undefined") q.ctx = "";
      });
      if (typeof data.ctx === "undefined") data.ctx = "";

      let apiKey = localStorage.getItem(GROQ_KEY) || "";
      // The access key in plain text — sent to /api/cotizar, which verifies
      // its SHA-256 against the COTIZADOR_KEY_HASH env var.
      let clave = "";
      let busy = false;

      function save() {
        data.updatedAt = Date.now();
        const idx = quotes.findIndex((q) => q.id === data.id);
        if (idx === -1) quotes.push(data);
        else quotes[idx] = data;
        try {
          localStorage.setItem(QUOTES_KEY, JSON.stringify(quotes));
          localStorage.setItem(CURRENT_KEY, data.id);
        } catch (e) {}
        syncRemote();
      }

      // Si la cotización ya tiene link (remoteId), cada edición se sube sola
      // a Supabase con un debounce, así el cliente siempre ve la versión
      // actual sin tener que volver a copiar el link. Best-effort: si falla
      // (sin red, backend apagado), el próximo cambio o copia lo reintenta.
      let syncTimer: ReturnType<typeof setTimeout>;
      function syncRemote() {
        if (!data.remoteId) return;
        const snapshot = data;
        clearTimeout(syncTimer);
        syncTimer = setTimeout(() => {
          saveQuoteRemote(snapshot.remoteId, snapshot, clave).catch(() => {});
        }, 1200);
      }

      /* ---------- Rendering ---------- */
      const paper = $("czPaper");
      const cover = $("czCover");
      const valor = $("czValor");
      const thanks = $("czThanks");

      function renderPaper() {
        const onChange = (_d: any, rerender: any) => {
          save();
          if (rerender) renderPaper();
        };
        renderCover(cover, data);
        renderDoc(paper, data, { editable: true, onChange });
        renderValor(valor, data, { editable: true, onChange });
        renderThanks(thanks, data, { editable: true, onChange });
      }

      function refresh() {
        const t = labelsFor(data.lang);
        document.documentElement.lang = data.lang;
        $("hdrTag").textContent = t.cotizador;
        $("btnListLabel").textContent = t.guardadas;
        $("btnListCount").textContent = String(quotes.length);
        $("btnCopy").textContent = t.copiarLink;
        $("btnPrint").textContent = t.descargar;
        $("btnNew").textContent = t.nueva;
        $("drawerTitle").textContent = t.guardadas;
        document.querySelectorAll<HTMLElement>(".cz-pill").forEach((p) => {
          const f = p.dataset.filtro;
          p.textContent =
            f === "aprobadas" ? t.filtroAprobadas : f === "rechazadas" ? t.filtroRechazadas : t.filtroTodas;
        });
        $("btnDrawerNew").textContent = t.nueva;
        $("lblCliente").textContent = t.datosCliente;
        $("lblContexto").textContent = t.contexto;
        $("lblTarifa").textContent = t.tarifa;
        $("lblDeadline").textContent = t.fechaLimite;
        $("inDeadline").setAttribute("aria-label", t.fechaLimite);
        $("inNombre").placeholder = t.phNombre;
        $("inEmpresa").placeholder = t.phEmpresa;
        $("inContacto").placeholder = t.phContacto;
        $("inFecha").placeholder = t.fecha;
        $("inCtx").placeholder = t.phContexto;
        // Placeholders aren't accessible names — mirror them as labels.
        $("inNombre").setAttribute("aria-label", t.phNombre);
        $("inEmpresa").setAttribute("aria-label", t.phEmpresa);
        $("inContacto").setAttribute("aria-label", t.phContacto);
        $("inNumero").setAttribute("aria-label", "Nº");
        $("inFecha").setAttribute("aria-label", t.fecha);
        $("inCtx").setAttribute("aria-label", t.contexto);
        $("inRate").setAttribute("aria-label", t.tarifa);
        $("inApiKey").setAttribute("aria-label", "Groq API key");
        $("btnDrawerClose").setAttribute("aria-label", t.cerrar);
        $("hintApi").textContent = t.apiHint;
        $("hintGen").textContent = t.hint;
        $("btnGenerate").textContent = busy ? t.generando : t.generar;
        // Sin propuesta: solo "Generar". Con propuesta: "Guardar cambios" +
        // terciario "Regenerar", y aparecen link/PDF.
        $("btnGenerate").hidden = !!data.generado;
        $("btnSave").hidden = !data.generado;
        $("btnSave").textContent = t.guardarCambios;
        $("btnRegen").hidden = !data.generado;
        $("btnRegen").textContent = busy ? t.generando : t.regenerar;
        $("sidebarActions").hidden = !data.generado;
        $("langEs").classList.toggle("is-active", data.lang === "es");
        $("langEn").classList.toggle("is-active", data.lang === "en");

        $("curNumero").textContent = data.meta.numero || "—";
        $("curTitulo").textContent = data.q.proyecto || t.sinTitulo;

        $("inNombre").value = data.meta.nombre;
        $("inEmpresa").value = data.meta.empresa;
        $("inContacto").value = data.meta.contacto;
        $("inNumero").value = data.meta.numero;
        $("inFecha").value = data.meta.fecha;
        $("inCtx").value = data.ctx || "";
        $("inDeadline").value = data.meta.deadline || "";
        $("inRate").value = data.rate;
        $("inMoneda").value = data.moneda;
        $("inApiKey").value = apiKey;

        $("cmTitle").textContent = t.comentarios;
        $("btnCommentsClose").setAttribute("aria-label", t.cerrar);

        renderList();
        renderPaper();
        loadComments();
      }

      /* ---------- Client comments (read-only) ---------- */
      // Cada cotización tiene su propio hilo, así que un fetch en vuelo puede
      // llegar después de que ya cambiaste de cotización: el token descarta
      // las respuestas que ya no corresponden a la que está abierta.
      let commentsToken = 0;
      let commentsOpen = false;
      // Estado de la cotización abierta (según su hilo). Aprobada y rechazada
      // son excluyentes.
      let aprobada = false;
      let rechazada = false;
      // Estado por cotización (id → bool) para pintarlo también en el drawer
      // sin re-consultar en cada render.
      const aprobadasMap = new Map<string, boolean>();
      const rechazadasMap = new Map<string, boolean>();
      // Pill activa del drawer: "todas" | "aprobadas" | "rechazadas".
      let filtroActivo = "todas";

      // Refleja el estado de la cotización abierta en el sidebar: sin estado
      // muestra las dos CTAs; aprobada, el sello verde; rechazada, el rojo.
      function renderAprobacion() {
        const t = labelsFor(data.lang);
        const sinEstado = !aprobada && !rechazada;
        $("btnAprobar").textContent = t.aprobar;
        $("btnRechazar").textContent = t.rechazar;
        $("estadoCtas").hidden = !sinEstado;
        $("aprobadaSello").hidden = !aprobada;
        $("aprobadaTagText").textContent = t.aprobada;
        $("btnQuitarAprobacion").textContent = t.eliminarAprobacion;
        $("rechazadaSello").hidden = !rechazada;
        $("rechazadaTagText").textContent = t.rechazada;
        $("btnQuitarRechazo").textContent = t.quitarRechazo;
      }

      async function loadComments() {
        const t = labelsFor(data.lang);
        const token = ++commentsToken;
        const quoteId = data.id;
        let comentarios: any[];
        try {
          comentarios = await fetchComentarios(quoteId);
        } catch (e) {
          // Endpoint apagado o sin configurar: los controles no aparecen.
          if (token !== commentsToken) return;
          $("btnComments").hidden = true;
          $("aprobacionGroup").hidden = true;
          $("czComments").hidden = true;
          commentsOpen = false;
          return;
        }
        if (token !== commentsToken) return;

        // El estado vive en el hilo: presente la marca → aprobada / rechazada.
        aprobada = comentarios.some(esAprobacion);
        rechazada = comentarios.some(esRechazo);
        aprobadasMap.set(quoteId, aprobada);
        rechazadasMap.set(quoteId, rechazada);
        $("aprobacionGroup").hidden = false;
        renderAprobacion();

        $("btnComments").hidden = false;
        $("btnComments").textContent = `${t.comentarios} (${comentarios.length})`;
        $("btnComments").classList.toggle("is-flagged", comentarios.length > 0);
        renderComentarios($("cmList"), comentarios, {
          lang: data.lang,
          vacio: t.sinComentarios,
          anon: t.anonimo,
        });
        $("czComments").hidden = !commentsOpen;
      }

      $("btnComments").addEventListener("click", () => {
        commentsOpen = !commentsOpen;
        $("czComments").hidden = !commentsOpen;
      });
      $("btnCommentsClose").addEventListener("click", () => {
        commentsOpen = false;
        $("czComments").hidden = true;
      });

      /* ---------- Estado (aprobar / rechazar) desde el admin ---------- */
      // Aprobar y rechazar publican un comentario marcado en el hilo; quitar el
      // estado borra esas marcas (con la clave). Aprobada y rechazada son
      // excluyentes: al marcar una se limpia la otra si estaba puesta.
      let aprobacionBusy = false;

      // Cambia el estado de una cotización cualquiera (por id) y sincroniza
      // sidebar, mapas y drawer. `estado`: "aprobada" | "rechazada" | "ninguno".
      async function setEstado(quoteId: string, meta: any, estado: string) {
        if (aprobacionBusy) return;
        const t = labelsFor(data.lang);
        const eraAprobada = aprobadasMap.get(quoteId) === true;
        aprobacionBusy = true;
        try {
          if (estado === "aprobada") {
            if (rechazadasMap.get(quoteId)) await deleteAprobacion(quoteId, clave, "rechazo");
            await postComentario({
              quote: quoteId,
              autor: "No Flag Brand",
              texto: t.aprobadaComentario,
              numero: (meta && meta.numero) || "",
              cliente: [meta && meta.nombre, meta && meta.empresa].filter(Boolean).join(" · "),
            });
            toast(t.aprobadaToast);
          } else if (estado === "rechazada") {
            if (aprobadasMap.get(quoteId)) await deleteAprobacion(quoteId, clave, "aprobacion");
            await postComentario({
              quote: quoteId,
              autor: "No Flag Brand",
              texto: t.rechazadaComentario,
              numero: (meta && meta.numero) || "",
              cliente: [meta && meta.nombre, meta && meta.empresa].filter(Boolean).join(" · "),
            });
            toast(t.rechazadaToast);
          } else {
            await deleteAprobacion(quoteId, clave, "todos");
            toast(eraAprobada ? t.aprobacionQuitada : t.rechazoQuitado);
          }
          aprobadasMap.set(quoteId, estado === "aprobada");
          rechazadasMap.set(quoteId, estado === "rechazada");
          if (quoteId === data.id) {
            aprobada = estado === "aprobada";
            rechazada = estado === "rechazada";
            renderAprobacion();
          }
          if (!drawer.hidden) renderList();
        } catch (err) {
          toast(t.errAprobacion);
        } finally {
          aprobacionBusy = false;
        }
      }

      $("btnAprobar").addEventListener("click", async () => {
        $("btnAprobar").disabled = true;
        await setEstado(data.id, data.meta, "aprobada");
        $("btnAprobar").disabled = false;
      });
      $("btnRechazar").addEventListener("click", async () => {
        $("btnRechazar").disabled = true;
        await setEstado(data.id, data.meta, "rechazada");
        $("btnRechazar").disabled = false;
      });
      $("btnQuitarAprobacion").addEventListener("click", async () => {
        $("btnQuitarAprobacion").disabled = true;
        await setEstado(data.id, data.meta, "ninguno");
        $("btnQuitarAprobacion").disabled = false;
      });
      $("btnQuitarRechazo").addEventListener("click", async () => {
        $("btnQuitarRechazo").disabled = true;
        await setEstado(data.id, data.meta, "ninguno");
        $("btnQuitarRechazo").disabled = false;
      });

      /* ---------- Saved quotes drawer ---------- */
      // Heroicons "check" (mismo icono que el resto del sitio) para el badge
      // de aprobada en el drawer y el sello del sidebar.
      const CHECK_SVG =
        '<svg class="cz-check" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.4" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>';
      // Heroicons "x-mark" para el badge de rechazada en el drawer.
      const X_SVG =
        '<svg class="cz-x" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.4" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" /></svg>';

      function renderList() {
        const t = labelsFor(data.lang);
        const list = $("drawerList");
        list.textContent = "";
        if (!quotes.length) {
          const empty = document.createElement("p");
          empty.className = "cz-hint";
          empty.textContent = t.vacio;
          list.appendChild(empty);
          return;
        }
        const sorted = [...quotes].sort((a, b) => (b.updatedAt || 0) - (a.updatedAt || 0));
        // La pill activa filtra qué cotizaciones se listan.
        const visibles = sorted.filter((q) => {
          if (filtroActivo === "aprobadas") return aprobadasMap.get(q.id) === true;
          if (filtroActivo === "rechazadas") return rechazadasMap.get(q.id) === true;
          return true;
        });
        if (!visibles.length) {
          const empty = document.createElement("p");
          empty.className = "cz-hint";
          empty.textContent = t.vacio;
          list.appendChild(empty);
          return;
        }
        for (const q of visibles) {
          const esAprobada = aprobadasMap.get(q.id) === true;
          const esRechazada = rechazadasMap.get(q.id) === true;
          const item = document.createElement("div");
          item.className =
            "cz-quote-item" +
            (q.id === data.id ? " is-active" : "") +
            (esAprobada ? " is-approved" : "") +
            (esRechazada ? " is-rejected" : "");

          const open = document.createElement("button");
          open.type = "button";
          open.className = "cz-quote-open";
          const line1 = document.createElement("div");
          line1.className = "cz-quote-line1";
          // Número + badge de aprobada (si aplica) agrupados a la izquierda.
          const numWrap = document.createElement("div");
          numWrap.className = "cz-quote-num-wrap";
          const num = document.createElement("span");
          num.textContent = q.meta.numero || "—";
          numWrap.appendChild(num);
          if (esAprobada) {
            const badge = document.createElement("span");
            badge.className = "cz-quote-aprobada";
            badge.innerHTML = CHECK_SVG;
            badge.appendChild(document.createTextNode(t.aprobada));
            numWrap.appendChild(badge);
          } else if (esRechazada) {
            const badge = document.createElement("span");
            badge.className = "cz-quote-rechazada";
            badge.innerHTML = X_SVG;
            badge.appendChild(document.createTextNode(t.rechazada));
            numWrap.appendChild(badge);
          }
          const total = document.createElement("span");
          total.textContent = fmtMoney(totalOf(q), q.moneda, q.lang);
          line1.append(numWrap, total);
          const line2 = document.createElement("div");
          line2.className = "cz-quote-line2";
          line2.textContent = q.q.proyecto || t.sinTitulo;
          const line3 = document.createElement("div");
          line3.className = "cz-quote-line3";
          line3.textContent =
            [q.meta.nombre, q.meta.empresa].filter(Boolean).join(" · ") || "—";
          open.append(line1, line2, line3);
          open.addEventListener("click", () => {
            data = q;
            try {
              localStorage.setItem(CURRENT_KEY, data.id);
            } catch (e) {}
            closeDrawer();
            refresh();
          });

          const actions = document.createElement("div");
          actions.className = "cz-quote-actions";
          const dup = document.createElement("button");
          dup.type = "button";
          dup.textContent = t.duplicar;
          dup.addEventListener("click", () => {
            const copy = JSON.parse(JSON.stringify(q));
            copy.id = genId();
            // Nunca heredar el remoteId: el duplicado aún no tiene su propio
            // link guardado, y si lo tuviera sería el del original.
            delete copy.remoteId;
            copy.meta.numero = nextNumero(quotes);
            copy.meta.fecha = todayStr(copy.lang);
            data = copy;
            save();
            closeDrawer();
            refresh();
          });
          const del = document.createElement("button");
          del.type = "button";
          del.textContent = t.eliminar;
          del.className = "cz-quote-del";
          // El borrado se confirma en un modal con sus botones (openDeleteModal),
          // no dentro de la tarjeta.
          del.addEventListener("click", () => openDeleteModal(q));
          actions.append(dup, del);

          // Acciones de estado directo desde el drawer: si ya tiene estado, se
          // ofrece quitarlo; si no, aprobar o marcar como rechazada.
          if (esAprobada) {
            const unap = document.createElement("button");
            unap.type = "button";
            unap.className = "cz-quote-unap";
            unap.textContent = t.quitarAprobacion;
            unap.addEventListener("click", async () => {
              unap.disabled = true;
              await setEstado(q.id, q.meta, "ninguno");
              if (!drawer.hidden) renderList();
            });
            actions.append(unap);
          } else if (esRechazada) {
            const unrej = document.createElement("button");
            unrej.type = "button";
            unrej.className = "cz-quote-unrej";
            unrej.textContent = t.quitarRechazo;
            unrej.addEventListener("click", async () => {
              unrej.disabled = true;
              await setEstado(q.id, q.meta, "ninguno");
              if (!drawer.hidden) renderList();
            });
            actions.append(unrej);
          } else {
            const ap = document.createElement("button");
            ap.type = "button";
            ap.className = "cz-quote-ap";
            ap.textContent = t.aprobarCorto;
            ap.addEventListener("click", async () => {
              ap.disabled = true;
              await setEstado(q.id, q.meta, "aprobada");
              if (!drawer.hidden) renderList();
            });
            const rej = document.createElement("button");
            rej.type = "button";
            rej.className = "cz-quote-rej";
            rej.textContent = t.rechazarCorto;
            rej.addEventListener("click", async () => {
              rej.disabled = true;
              await setEstado(q.id, q.meta, "rechazada");
              if (!drawer.hidden) renderList();
            });
            actions.append(ap, rej);
          }

          item.append(open, actions);
          list.appendChild(item);
        }
      }

      function newQuote(lang: string) {
        const fresh = defaultQuote(lang) as any;
        fresh.meta.numero = nextNumero(quotes);
        // Sin propuesta aún: esconde link/PDF y muestra "Generar propuesta".
        fresh.generado = false;
        fresh.ctx = "";
        return fresh;
      }

      const drawer = $("czDrawer");
      const backdrop = $("drawerBackdrop");

      /* ---------- Modal de confirmación de borrado ---------- */
      // La cotización pendiente de borrar mientras el modal está abierto.
      let delTarget: any = null;

      function openDeleteModal(q: any) {
        const t = labelsFor(data.lang);
        delTarget = q;
        $("delTitle").textContent = t.eliminarTitulo;
        $("delQuote").textContent =
          [q.meta.numero, q.q.proyecto || t.sinTitulo].filter(Boolean).join(" · ");
        $("delText").textContent = t.eliminarTexto;
        $("delCancel").textContent = t.cancelar;
        $("delConfirm").textContent = t.siEliminar;
        $("delBackdrop").hidden = false;
        // Foco en la salida segura: Enter no borra por accidente.
        $("delCancel").focus();
      }
      function closeDeleteModal() {
        delTarget = null;
        $("delBackdrop").hidden = true;
      }

      function deleteQuote(q: any) {
        quotes = quotes.filter((x) => x.id !== q.id);
        try {
          localStorage.setItem(QUOTES_KEY, JSON.stringify(quotes));
        } catch (e) {}
        if (q.remoteId) {
          // Cancela cualquier auto-sync pendiente para que no re-cree la
          // cotización en el backend justo después de borrarla.
          if (q.id === data.id) clearTimeout(syncTimer);
          // Best-effort: si nunca se guardó en el backend (o ya no está
          // configurado), esto falla en silencio — la cotización local
          // ya se borró, que es lo que importa.
          deleteQuoteRemote(q.remoteId, clave).catch(() => {});
        }
        if (q.id === data.id) {
          data = quotes[quotes.length - 1] || newQuote(data.lang);
        }
        refresh();
        if (!drawer.hidden) renderList();
      }

      $("delCancel").addEventListener("click", closeDeleteModal);
      $("delBackdrop").addEventListener("click", (e: any) => {
        // Solo el clic en el fondo cierra; dentro del modal no.
        if (e.target === $("delBackdrop")) closeDeleteModal();
      });
      $("delConfirm").addEventListener("click", () => {
        if (!delTarget) return;
        deleteQuote(delTarget);
        closeDeleteModal();
      });

      // Consulta el estado de cada cotización guardada para pintarlo en el
      // drawer. Best-effort en paralelo: las que fallen (o si el endpoint está
      // apagado) simplemente no muestran badge.
      async function refreshAprobadas() {
        await Promise.all(
          quotes.map(async (q) => {
            try {
              const c = await fetchComentarios(q.id);
              aprobadasMap.set(q.id, c.some(esAprobacion));
              rechazadasMap.set(q.id, c.some(esRechazo));
            } catch (e) {}
          })
        );
      }

      // Cierre animado: .is-open dispara la transición CSS y `hidden` se
      // aplica cuando termina (mismo tiempo que en cotizador.css).
      let drawerCloseTimer: any;

      async function openDrawer() {
        clearTimeout(drawerCloseTimer);
        renderList();
        drawer.hidden = false;
        backdrop.hidden = false;
        // Doble rAF: el navegador pinta primero el estado inicial (panel fuera
        // de pantalla) y hasta el siguiente frame entra la transición.
        requestAnimationFrame(() =>
          requestAnimationFrame(() => {
            if (drawer.hidden) return; // se cerró antes de arrancar
            drawer.classList.add("is-open");
            backdrop.classList.add("is-open");
          })
        );
        // Pinta ya con lo que haya en el mapa; al volver el fetch, re-pinta con
        // los badges actualizados (si el drawer sigue abierto).
        await refreshAprobadas();
        if (!drawer.hidden) renderList();
      }
      function closeDrawer() {
        drawer.classList.remove("is-open");
        backdrop.classList.remove("is-open");
        drawerCloseTimer = setTimeout(() => {
          drawer.hidden = true;
          backdrop.hidden = true;
        }, 350);
      }
      // Pills de filtro: cambian `filtroActivo` y re-pintan la lista.
      document.querySelectorAll<HTMLElement>(".cz-pill").forEach((pill) => {
        pill.addEventListener("click", () => {
          filtroActivo = pill.dataset.filtro || "todas";
          document.querySelectorAll<HTMLElement>(".cz-pill").forEach((p) => {
            const on = p === pill;
            p.classList.toggle("is-active", on);
            p.setAttribute("aria-pressed", String(on));
          });
          renderList();
        });
      });

      // El toggle mira .is-open (no `hidden`): durante el cierre animado el
      // panel sigue sin `hidden` y un clic debe reabrirlo, no re-cerrarlo.
      $("btnList").addEventListener("click", () =>
        drawer.classList.contains("is-open") ? closeDrawer() : openDrawer()
      );
      $("btnDrawerClose").addEventListener("click", closeDrawer);
      backdrop.addEventListener("click", closeDrawer);
      document.addEventListener("keydown", (e) => {
        if (e.key !== "Escape") return;
        // El modal de borrado va encima del drawer: Escape lo cierra primero.
        if (!$("delBackdrop").hidden) {
          closeDeleteModal();
          return;
        }
        if (!drawer.hidden) closeDrawer();
      });
      $("btnDrawerNew").addEventListener("click", () => {
        data = newQuote(data.lang);
        save();
        closeDrawer();
        refresh();
      });

      /* ---------- Sidebar bindings ---------- */
      for (const id of ["inNombre", "inEmpresa", "inContacto", "inNumero", "inFecha"]) {
        $(id).addEventListener("input", (e: any) => {
          data.meta[e.currentTarget.dataset.key] = e.currentTarget.value;
          save();
          renderPaper();
        });
      }
      $("inCtx").addEventListener("input", (e: any) => {
        data.ctx = e.currentTarget.value;
        save();
      });
      $("inDeadline").addEventListener("change", (e: any) => {
        data.meta.deadline = e.currentTarget.value;
        save();
      });
      $("inRate").addEventListener("change", (e: any) => {
        data.rate = Number(e.currentTarget.value.replace(/[^0-9.]/g, "")) || 0;
        // Las partidas cotizadas por horas siguen la tarifa; las de precio
        // fijo (horas: null) se quedan como están — por eso son fijas.
        for (const inv of data.q.inversion) {
          if (inv.horas !== null && inv.horas !== undefined) {
            inv.precio = inv.horas * data.rate;
          }
        }
        save();
        renderPaper();
      });
      $("inMoneda").addEventListener("change", (e: any) => {
        data.moneda = e.currentTarget.value;
        save();
        renderPaper();
      });
      $("inApiKey").addEventListener("input", (e: any) => {
        apiKey = e.currentTarget.value;
        try {
          localStorage.setItem(GROQ_KEY, apiKey);
        } catch (err) {}
      });

      for (const id of ["langEs", "langEn"]) {
        $(id).addEventListener("click", (e: any) => {
          data.lang = e.currentTarget.dataset.lang;
          save();
          refresh();
        });
      }

      /* ---------- Actions ---------- */
      let toastTimer: ReturnType<typeof setTimeout>;
      function toast(msg: string) {
        const node = $("czToast");
        node.textContent = msg;
        node.classList.add("is-visible");
        clearTimeout(toastTimer);
        toastTimer = setTimeout(() => node.classList.remove("is-visible"), 2200);
      }

      $("btnCopy").addEventListener("click", async () => {
        const t = labelsFor(data.lang);
        let url;
        try {
          // Una vez generado, el id del link no cambia aunque después se
          // edite el número o el nombre del cliente — el link que ya tiene
          // el cliente sigue siendo válido y ve siempre la versión actual.
          const id = data.remoteId || quoteSlug(data);
          await saveQuoteRemote(id, data, clave);
          data.remoteId = id;
          save();
          // El save() de arriba agenda un auto-sync, pero esta versión ya
          // acaba de subirse — cancelarlo evita un POST redundante.
          clearTimeout(syncTimer);
          // `v=2` no lo lee el visor: solo hace que WhatsApp/Slack traten el
          // link como URL nueva y escaneen el preview actual en vez del que
          // tenían cacheado de antes del cambio de imagen OG.
          url = `${location.origin}/cotizador/ver?id=${encodeURIComponent(id)}&v=2`;
        } catch (e) {
          // Sin Supabase configurado (o si el guardado falla por lo que sea):
          // cae de vuelta al link largo de antes, que siempre funciona.
          const token = await encodeQuote(data);
          url = `${location.origin}/cotizador/ver?v=2#q=${token}`;
        }
        try {
          await navigator.clipboard.writeText(url);
          toast(t.linkCopiado + " ✓");
        } catch (e) {
          window.prompt("Copia el link:", url);
        }
      });

      $("btnPrint").addEventListener("click", () => {
        const prev = document.title;
        document.title = `Cotización ${data.meta.numero || ""} — No Flag Brand`.trim();
        window.print();
        document.title = prev;
      });

      // The current quote autosaves into the collection, so starting a new
      // one loses nothing — no confirmation needed.
      $("btnNew").addEventListener("click", () => {
        data = newQuote(data.lang);
        save();
        refresh();
      });

      // Generar y regenerar comparten flujo: la IA usa el contexto actual del
      // sidebar. `btn` es quién disparó, para deshabilitarlo mientras corre.
      async function runGenerate(btn: any) {
        if (busy) return;
        const t = labelsFor(data.lang);
        const errBox = $("genError");
        errBox.hidden = true;
        if (!(data.ctx || "").trim()) {
          errBox.textContent = t.errCtx;
          errBox.hidden = false;
          return;
        }
        busy = true;
        btn.disabled = true;
        btn.textContent = t.generando;
        try {
          data.q = await generateProposal({ ctx: data.ctx, data, apiKey, clave });
          data.generado = true;
          save();
          renderPaper();
        } catch (err: any) {
          errBox.textContent = err && err.message && /key/i.test(err.message) ? err.message : t.errGen;
          errBox.hidden = false;
        } finally {
          busy = false;
          btn.disabled = false;
          // refresh() repone textos y alterna Generar ↔ Guardar/Regenerar.
          refresh();
        }
      }

      $("btnGenerate").addEventListener("click", () => runGenerate($("btnGenerate")));
      $("btnRegen").addEventListener("click", () => runGenerate($("btnRegen")));

      // Guardado manual: mismo save() del autosave, pero con confirmación
      // visible — y sube el cambio al backend al instante, sin debounce.
      $("btnSave").addEventListener("click", () => {
        const t = labelsFor(data.lang);
        save();
        if (data.remoteId) {
          clearTimeout(syncTimer);
          saveQuoteRemote(data.remoteId, data, clave).catch(() => {});
        }
        toast(t.cambiosGuardados);
      });

      /* ---------- Access gate ---------- */
      const gate = $("czGate");
      const app = $("czApp");

      function unlock() {
        gate.hidden = true;
        app.hidden = false;
        // `hidden` needs display:none to win while locked, so the layout
        // display is applied here instead of inline in the markup.
        app.style.display = "contents";
        refresh();
      }

      $("czGateForm").addEventListener("submit", async (e: any) => {
        e.preventDefault();
        const t = labelsFor(data.lang);
        const value = $("gateInput").value;
        if ((await sha256hex(value)) === PASS_HASH) {
          clave = value;
          // Stored in plain text (only in this browser): the gate validates
          // it by hash, and /api/cotizar needs the original value.
          try {
            localStorage.setItem(AUTH_KEY, value);
          } catch (err) {}
          unlock();
        } else {
          $("gateError").textContent = t.claveIncorrecta;
          $("gateInput").value = "";
          $("gateInput").focus();
        }
      });

      (async () => {
        const stored = localStorage.getItem(AUTH_KEY) || "";
        if (stored && (await sha256hex(stored)) === PASS_HASH) {
          clave = stored;
          unlock();
        } else {
          $("gateInput").focus();
        }
      })();
    </script>
  </body>
</html>
