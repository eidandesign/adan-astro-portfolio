---
import { getCollection } from "astro:content";
import ConnectSection from "../../components/ConnectSection.astro";
import SEO from "../../components/SEO.astro";
import "../../styles/site.css";

export async function getStaticPaths() {
  const entries = (await getCollection("case-studies")).filter((e) => e.data.kind === "case-study");
  entries.sort((a, b) => a.data.order - b.data.order);
  return entries.map((entry, i) => ({
    params: { slug: entry.slug },
    props: { entry, next: entries[(i + 1) % entries.length] },
  }));
}

const { entry, next } = Astro.props;
const cs = entry.data;
const hasNext = next && next.slug !== entry.slug;
---

<html lang="en">
  <head>
    <SEO title={`${cs.title} — ${cs.subtitle} | Adan Careta`} description={cs.description} image={cs.heroImage} type="article" />
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "CreativeWork",
      name: cs.title,
      headline: `${cs.title} — ${cs.subtitle}`,
      description: cs.description,
      image: new URL(cs.heroImage, Astro.site).href,
      url: new URL(Astro.url.pathname, Astro.site).href,
      author: { "@type": "Person", name: "Adan Careta", url: "https://www.adancareta.com" },
      genre: "Product Design Case Study",
    })} />
  </head>
  <body class="body-2">
    <a href="/" class="button-return">
      <img src="/images/back_button.svg" loading="lazy" alt="" />
      <div class="paragraph">Home</div>
    </a>

    <!-- HEADER -->
    <section class="section-header">
      <img src={cs.heroImage} loading="eager" alt={cs.title} class="image-9" />
      <div class="content-header" id="contentHeader">
        <div class="content-project">
          <div class="div-block-36">
            <h1 class="titles medium">{cs.title}</h1>
            <p class="paragraph medium">{cs.subtitle}</p>
          </div>
          {cs.role && (
            <div class="data-text-box last _8-padding">
              <div class="labels">ROLE</div>
              <p class="paragraph medium">{cs.role}</p>
            </div>
          )}
          {cs.team && (
            <div class="data-text-box last _8-padding">
              <div class="labels">TEAM</div>
              <p class="paragraph medium">{cs.team}</p>
            </div>
          )}
          {cs.tech && (
            <div class="data-text-box last _8-padding">
              <div class="labels">Tech Used</div>
              <p class="paragraph medium">{cs.tech}</p>
            </div>
          )}
          {cs.overview && (
            <div class="data-text-box last _8-padding">
              <div class="labels">Project Overview</div>
              <p class="paragraph medium">{cs.overview}</p>
            </div>
          )}
        </div>
      </div>
    </section>

    <!-- DATA -->
    {cs.data.length > 0 && (
      <section class="section-data">
        <div class="div-block-28">
          <div class="section-wrapper">
            {cs.data.map((box, i) => (
              <div class={`data-text-box${i === cs.data.length - 1 ? " last" : ""}`} data-reveal>
                {box.icon && (
                  <div class="lottie-icon">
                    <div class="lottie-animation-2" data-lottie={`/lottie/${box.icon}.json`}></div>
                  </div>
                )}
                <div class="labels">{box.label}</div>
                <p class="paragraph medium">{box.text}</p>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- EXPLORATION / WIREFRAMES -->
    {cs.exploration && (
      <section class="section-wireframes">
        <div class="div-block-42">
          <div class="_1-columns-text" data-reveal>
            <h2 class="title medium">{cs.exploration.title}</h2>
            <div class="div-block-47">
              <p class="paragraph medium">{cs.exploration.text}</p>
            </div>
          </div>
          <div class="slider-cs" data-slider>
            <div class="slider-mask">
              {cs.exploration.images.map((img, i) => (
                <div class={`slide${i === 0 ? " active" : ""}`}>
                  <img src={img} loading="lazy" alt={`${cs.title} exploration ${i + 1}`} class="slide-image" />
                </div>
              ))}
            </div>
            <div class="slider-dots">
              {cs.exploration.images.map((_, i) => (
                <button class={`slider-dot${i === 0 ? " active" : ""}`} data-slide={i} aria-label={`Slide ${i + 1}`}></button>
              ))}
            </div>
          </div>
        </div>
      </section>
    )}

    <!-- DESIGN -->
    {cs.design && (
      <section class="section-designs">
        <div class="design-text" data-reveal>
          <h2 class="title xl left">Design</h2>
          <div class="data-text-box last design">
            <div class="title big">{cs.design.title}</div>
            <p class="paragraph medium">{cs.design.text}</p>
          </div>
        </div>
        <div class="card_component" data-reveal>
          {cs.design.images.map((img, i) => (
            <div class="card-2">
              <div class="card_image-wrapper-2">
                <img loading="lazy" src={img} alt={`${cs.title} design ${i + 1}`} class="card-image" />
              </div>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- PROTOTYPE -->
    {cs.prototype && (
      <section class="section-prototype">
        <div class="prototype-item" data-reveal>
          <div class="design-text">
            <h2 class="title xl left">Prototype</h2>
            <div class="data-text-box last design">
              <p class="paragraph medium">{cs.prototype.text}</p>
            </div>
            <a href={cs.prototype.url} target="_blank" rel="noopener" class="button-big">{cs.prototype.label}</a>
          </div>
        </div>
      </section>
    )}

    <!-- RESULTS -->
    {cs.results.length > 0 && (
      <section class="section-results">
        <div class="div-block-37">
          <div class="section-wrapper no-space _2">
            {cs.results.slice(0, 2).map((r) => (
              <div class="data-text-box full-border" data-reveal>
                <div class="labels">{r.label}</div>
                <div class="title xxl" data-count={r.value}>{r.value}</div>
                <p class="paragraph medium">{r.text}</p>
              </div>
            ))}
          </div>
          <div class="div-block-39" data-reveal>
            <h2 class="title xl center">Validation &amp; Results</h2>
          </div>
          <div class="section-wrapper no-space">
            {cs.results.slice(2).map((r) => (
              <div class="data-text-box full-border" data-reveal>
                <div class="labels">{r.label}</div>
                <div class="title xxl" data-count={r.value}>{r.value}</div>
                <p class="paragraph medium">{r.text}</p>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- CONCLUSIONS -->
    {cs.conclusions.length > 0 && (
      <section class="section-conclusions">
        <div class="div-block-28">
          <div class="div-block-29" data-reveal>
            <h2 class="title xl left">Conclusions</h2>
          </div>
          <div class="section-wrapper _2">
            {cs.conclusions.map((c, i) => (
              <div class={`data-text-box${i === cs.conclusions.length - 1 ? " last" : ""}`} data-reveal>
                <div class="labels">{c.label}</div>
                <p class="paragraph medium">{c.text}</p>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- NEXT PROJECT -->
    <section class="section-next-project">
      {hasNext ? (
        <a href={`/case-studies/${next.slug}`} class="next-project-link" data-reveal>
          <div class="labels">Next Project</div>
          <h2 class="title xl center">{next.data.title}</h2>
        </a>
      ) : (
        <h2 class="title xl center" data-reveal>Next Project Soon</h2>
      )}
    </section>

    <ConnectSection />

    <style is:global>
      /* ============ CASE STUDY TEMPLATE (from adan-portfolio.webflow.css) ============ */
      .body-2 {
        background-color: var(--surface-background);
      }

      .section-header {
        height: 100vh;
        position: relative;
        overflow: hidden;
      }
      .image-9 {
        object-fit: cover;
        object-position: 50% 0%;
        width: 100%;
        height: 100%;
        display: block;
      }
      .content-header {
        background-color: var(--surface-background);
        border-radius: 8px;
        display: flex;
        flex-flow: column;
        justify-content: flex-start;
        align-items: flex-start;
        width: 440px;
        position: absolute;
        top: 8%;
        right: 4%;
        opacity: 0; /* GSAP reveals */
      }
      .content-project {
        display: flex;
        gap: 16px;
        flex-flow: column;
        margin: 32px;
      }
      .div-block-36 {
        display: flex;
        flex-flow: column;
        align-items: flex-start;
        margin-bottom: 25px;
      }

      .data-text-box {
        display: flex;
        gap: 8px;
        flex-flow: column;
        border-right: 1px solid var(--border-light);
        border-radius: 8px 0 0 8px;
        width: 100%;
        padding: 40px 16px 40px 0;
      }
      .data-text-box.last {
        border-right-style: none;
        padding-right: 48px;
      }
      .data-text-box.last._8-padding {
        gap: 4px;
        padding: 8px;
      }
      .data-text-box.last.design {
        gap: 24px;
        align-self: center;
        width: 100%;
        margin-top: 20px;
        margin-bottom: 24px;
        padding: 0;
      }
      .data-text-box.full-border {
        border: 1px solid var(--border-light);
        border-radius: 8px;
        width: 400px;
        max-width: 100%;
        padding: 40px;
      }

      .section-data {
        max-width: 90%;
        margin: 120px auto 200px;
      }
      .div-block-28 {
        display: flex;
        gap: 40px;
        flex-flow: column;
        max-width: 100%;
        margin-left: auto;
        margin-right: auto;
      }
      .div-block-29 {
        align-self: center;
        width: 100%;
        display: flex;
      }
      .section-wrapper {
        display: grid;
        gap: 48px;
        grid-template-rows: auto;
        grid-template-columns: 1fr 1fr 1fr 1fr;
        max-width: 100%;
        margin-left: auto;
        margin-right: auto;
      }
      .section-wrapper.no-space {
        gap: 16px;
        grid-template-columns: 1fr 1fr;
        justify-items: center;
      }
      .section-wrapper.no-space._2,
      .section-wrapper._2 {
        grid-template-columns: 1fr 1fr;
      }
      .lottie-icon {
        margin-bottom: 24px;
      }
      .lottie-animation-2 {
        width: 28px;
      }

      .section-wireframes {
        border-style: solid none;
        border-width: 1px;
        border-color: var(--border-light);
        max-width: 100%;
        margin: 120px auto 200px;
      }
      .div-block-42 {
        display: flex;
        gap: 40px;
      }
      ._1-columns-text {
        display: flex;
        gap: 22px;
        flex-flow: column;
        align-self: center;
        align-items: flex-start;
        width: 40%;
        margin-left: 90px;
        margin-right: 80px;
      }
      .div-block-47 {
        display: flex;
        gap: 40px;
        flex-flow: column;
      }

      /* Slider (replaces the Webflow slider) */
      .slider-cs {
        width: 100%;
        height: 100vh;
        overflow: hidden;
        position: relative;
      }
      .slider-mask {
        height: 100%;
        position: relative;
        overflow: hidden;
      }
      .slide {
        position: absolute;
        inset: 0;
        opacity: 0;
        transition: opacity 0.9s ease;
      }
      .slide.active {
        opacity: 1;
      }
      .slide-image {
        object-fit: cover;
        width: 100%;
        height: 100%;
      }
      .slider-dots {
        position: absolute;
        bottom: 24px;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        gap: 8px;
      }
      .slider-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        border: none;
        background: rgba(255, 255, 255, 0.4);
        cursor: pointer;
        padding: 0;
        transition: background 0.3s;
      }
      .slider-dot.active {
        background: #fff;
      }

      .section-designs {
        max-width: 90%;
        margin: 120px auto 200px;
      }
      .design-text {
        display: flex;
        gap: 8px;
        flex-flow: column;
        justify-content: flex-start;
        align-items: flex-start;
        width: 60%;
        margin: 80px auto;
      }
      .card_component {
        display: flex;
        gap: 1.5rem;
        justify-content: space-between;
        margin-top: 64px;
      }
      .card-2 {
        border-radius: 1rem;
        flex: 25%;
        width: 100%;
        height: 38em;
        transition: flex-basis 0.6s cubic-bezier(0.645, 0.045, 0.355, 1);
        position: relative;
        overflow: hidden;
      }
      .card-2:hover {
        flex-basis: 100%;
      }
      .card_image-wrapper-2 {
        width: 100%;
        height: 100%;
        position: absolute;
        inset: 0;
      }
      .card-image {
        z-index: 1;
        object-fit: cover;
        width: 100%;
        height: 100%;
        display: block;
      }

      .section-prototype {
        max-width: 90%;
        margin-left: auto;
        margin-right: auto;
      }
      .prototype-item {
        background-image: linear-gradient(#131920, #0c1015 44%, #131920);
        border: 1px solid #313c57;
        border-radius: 20px;
        margin-top: 40px;
        overflow: hidden;
      }

      .section-results {
        max-width: 90%;
        margin: 80px auto 200px;
      }
      .div-block-37 {
        display: flex;
        gap: 48px;
        flex-flow: column;
        width: 100%;
      }
      .div-block-39 {
        width: 100%;
      }

      .section-conclusions {
        max-width: 90%;
        margin: 120px auto 200px;
      }

      .section-next-project {
        max-width: 90%;
        margin: 120px auto 200px;
      }
      .next-project-link {
        display: flex;
        flex-flow: column;
        gap: 16px;
        align-items: center;
        text-align: center;
      }
      .next-project-link .labels {
        text-align: center;
        width: auto;
      }
      .next-project-link:hover .title {
        text-decoration: underline;
      }

      @media (max-width: 991px) {
        .section-header {
          height: 660px;
        }
        .content-header {
          width: 60%;
          left: auto;
          right: 5%;
          top: 1%;
          padding: 24px;
        }
        .section-wrapper {
          grid-template-columns: 1fr 1fr;
        }
        ._1-columns-text {
          width: 90%;
          margin-bottom: 48px;
        }
        .div-block-42 {
          flex-flow: column;
        }
        .slider-cs {
          height: 60vh;
        }
      }

      @media (max-width: 767px) {
        .section-header {
          height: auto;
        }
        .image-9 {
          height: 260px;
        }
        .content-header {
          border-radius: 15px;
          width: 100%;
          position: relative;
          top: 0;
          left: 0;
          right: 0;
        }
        .section-data {
          margin-top: 80px;
        }
        .section-wrapper,
        .section-wrapper.no-space,
        .section-wrapper.no-space._2,
        .section-wrapper._2 {
          grid-template-columns: 1fr;
        }
        .data-text-box {
          border-right-style: none;
          padding-top: 0;
          padding-bottom: 0;
          padding-right: 0;
        }
        .data-text-box.full-border {
          width: 100%;
          padding: 40px;
        }
        .section-wireframes {
          margin-bottom: 89px;
        }
        .section-designs {
          margin-bottom: 0;
        }
        .section-results,
        .section-conclusions,
        .section-next-project {
          margin-top: 40px;
          margin-bottom: 40px;
        }
        .slider-cs {
          height: 40vh;
        }
        .card_component {
          gap: 0.8rem;
          flex-flow: column;
          height: auto;
        }
        .card-2 {
          height: 300px;
        }
        .design-text {
          width: 100%;
        }
        .prototype-item {
          padding-left: 16px;
          padding-right: 16px;
        }
      }
    </style>

    <script>
      import gsap from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";
      import lottie from "lottie-web";

      gsap.registerPlugin(ScrollTrigger);

      /* Header card entrance (same motion as the Webflow interaction) */
      gsap.to("#contentHeader", { opacity: 1, y: 0, duration: 1.1, ease: "power3.out", delay: 0.2 });
      gsap.from("#contentHeader", { y: -88, duration: 1.1, ease: "power3.out", delay: 0.2 });

      /* Hero image slow zoom */
      gsap.from(".image-9", { scale: 1.08, duration: 2.2, ease: "power2.out" });

      /* Lottie data icons */
      document.querySelectorAll<HTMLElement>("[data-lottie]").forEach((el) => {
        lottie.loadAnimation({
          container: el,
          renderer: "svg",
          loop: true,
          autoplay: true,
          path: el.dataset.lottie!,
        });
      });

      /* Generic reveals */
      document.querySelectorAll<HTMLElement>("[data-reveal]").forEach((el) => {
        gsap.to(el, {
          opacity: 1,
          y: 0,
          duration: 1,
          ease: "power3.out",
          scrollTrigger: { trigger: el, start: "top 88%", once: true },
        });
      });

      /* Results counters — animate numeric values when they scroll in */
      document.querySelectorAll<HTMLElement>("[data-count]").forEach((el) => {
        const raw = el.dataset.count || "";
        const match = raw.match(/-?\d+(\.\d+)?/);
        if (!match) return;
        const target = parseFloat(match[0]);
        const suffix = raw.slice(raw.indexOf(match[0]) + match[0].length);
        const prefix = raw.slice(0, raw.indexOf(match[0]));
        const counter = { v: 0 };
        gsap.to(counter, {
          v: target,
          duration: 1.6,
          ease: "power2.out",
          scrollTrigger: { trigger: el, start: "top 88%", once: true },
          onUpdate() {
            el.textContent = `${prefix}${Math.round(counter.v)}${suffix}`;
          },
        });
      });

      /* Exploration slider — autoplay fade, matching the Webflow slider behavior */
      document.querySelectorAll<HTMLElement>("[data-slider]").forEach((slider) => {
        const slides = [...slider.querySelectorAll<HTMLElement>(".slide")];
        const dots = [...slider.querySelectorAll<HTMLElement>(".slider-dot")];
        if (slides.length < 2) return;
        let current = 0;
        let timer: ReturnType<typeof setInterval>;

        const show = (i: number) => {
          slides[current].classList.remove("active");
          dots[current]?.classList.remove("active");
          current = (i + slides.length) % slides.length;
          slides[current].classList.add("active");
          dots[current]?.classList.add("active");
        };
        const play = () => {
          clearInterval(timer);
          timer = setInterval(() => show(current + 1), 4000);
        };
        dots.forEach((dot, i) =>
          dot.addEventListener("click", () => {
            show(i);
            play();
          })
        );
        play();
      });
    </script>
  </body>
</html>
