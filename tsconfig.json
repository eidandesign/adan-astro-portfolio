{
  "extends": "astro/tsconfigs/strict",
  "exclude": ["dist", "node_modules", "sanity", "sanity.config.ts", ".sanity"],
  "compilerOptions": {
    "jsxImportSource": "react",
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@components/*": ["src/components/*"],
      "@layouts/*": ["src/layouts/*"],
      "@utils/*": ["src/utils/*"],
      "@types/*": ["src/types/*"]
    }
  }
}
